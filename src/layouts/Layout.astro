---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
}

const { 
  title = "Pakistan Data Management Services", 
  description = "Pioneering Islamic digital innovation and software development since 1979. Creators of Quran Majeed, EasyUrdu, and custom enterprise solutions." 
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dir = lang === 'en' ? 'ltr' : 'rtl';
const searchParams = Astro.url.searchParams;
const hideChrome = searchParams.get('webview') === '1' || searchParams.get('view') === 'app';

// Helper to determine active link
const pathname = new URL(Astro.request.url).pathname;
const cleanPathname = pathname.replace(new RegExp(`^/${lang}`), '') || '/';
const isActive = (path: string) => {
  if (path === '/' && cleanPathname === '/') return true;
  if (path !== '/' && cleanPathname.startsWith(path)) return true;
  return false;
};

const productLinks = [
  {
    href: getRelativeLocaleUrl(lang, '/products/quran-majeed'),
    label: 'Quran Majeed'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/quran-majeed-mac'),
    label: 'Quran Majeed Mac'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/quran-pak'),
    label: 'Quran Pak'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/hadith-app'),
    label: 'Hadith App'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/3d-salah-guide'),
    label: '3D Salah Guide'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/easyurdu'),
    label: 'Easy Urdu Keyboard'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/arabicfont'),
    label: 'PDMS Saleem Quran Font'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products/kitabi'),
    label: 'Kitabi'
  },
  {
    href: getRelativeLocaleUrl(lang, '/products'),
    label: 'More Products'
  }
];

const projectLinks = [
  {
    href: getRelativeLocaleUrl(lang, '/projects/nadra-software'),
    label: 'NADRA'
  },
  {
    href: getRelativeLocaleUrl(lang, '/projects/quran-printing-complex-project'),
    label: 'King Fahad'
  },
  {
    href: getRelativeLocaleUrl(lang, '/projects/quranexplorer'),
    label: 'QuranExplorer'
  },
  {
    href: getRelativeLocaleUrl(lang, '/projects/nara-national-alien-registration-authority'),
    label: 'NARA'
  },
  {
    href: getRelativeLocaleUrl(lang, '/projects/imagine'),
    label: 'Imagine'
  }
];
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | PDMS</title>
    <meta name="title" content={`${title} | PDMS`} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | PDMS`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://pakdata-pearl.vercel.app/images/logo.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${title} | PDMS`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://pakdata-pearl.vercel.app/images/logo.png" />

    <!-- Custom Language Fonts -->
    {lang === 'ur' && <link rel="preload" href="/fonts/ur.ttf" as="font" type="font/ttf" crossorigin />}
    {lang === 'ar' && <link rel="preload" href="/fonts/ar.ttf" as="font" type="font/ttf" crossorigin />}
    <style is:global>
      @font-face {
        font-family: 'UrduFont';
        src: url('/fonts/ur.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'ArabicFont';
        src: url('/fonts/ar.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      :lang(ur), :lang(ur) *, 
      :lang(ur) h1, :lang(ur) h2, :lang(ur) h3, :lang(ur) h4, :lang(ur) h5, :lang(ur) h6, :lang(ur) p, :lang(ur) a, :lang(ur) span, :lang(ur) div {
        font-family: 'UrduFont', 'Noto Nastaliq Urdu', Arial, sans-serif !important;
      }
      html:lang(ur) {
        line-height: 2.2;
        --text-scale: 1.25;
      }
      :lang(ar), :lang(ar) *, 
      :lang(ar) h1, :lang(ar) h2, :lang(ar) h3, :lang(ar) h4, :lang(ar) h5, :lang(ar) h6, :lang(ar) p, :lang(ar) a, :lang(ar) span, :lang(ar) div {
        font-family: 'ArabicFont', 'Amiri', 'Traditional Arabic', Arial, sans-serif !important;
      }
      html:lang(ar) {
        line-height: 2;
        --text-scale: 1.25;
      }
    </style>
  </head>
  <body class:list={[hideChrome && 'webview-shell']}>

    <!-- Navigation Header -->
    {!hideChrome && (
    <header class="header">
      <div class="container header-container">
        <!-- Logo -->
        <a href={getRelativeLocaleUrl(lang, '/')} class="logo-wrap" id="logo-nav-link">
          <img src="/images/logo.png" alt="PDMS Logo" class="logo-img" />
          <div class="logo-text">
          </div>
        </a>

        <!-- Desktop Navigation Links -->
        <nav class="nav-desktop">
          <a href={getRelativeLocaleUrl(lang, '/')} class={`nav-link ${isActive('/') ? 'active' : ''}`} id="nav-home">{t('nav.home')}</a>
          <div class={`nav-dropdown ${isActive('/projects') ? 'active' : ''}`} id="nav-projects-wrap">
            <a href={getRelativeLocaleUrl(lang, '/projects')} class={`nav-link nav-dropdown-link ${isActive('/projects') ? 'active' : ''}`} id="nav-projects">{t('nav.projects')}</a>
            <div class="nav-dropdown-menu" id="projects-dropdown-menu">
              {projectLinks.map((item) => (
                <a href={item.href} class="nav-dropdown-item">{item.label}</a>
              ))}
            </div>
          </div>
          <div class={`nav-dropdown ${isActive('/products') ? 'active' : ''}`} id="nav-products-wrap">
            <a href={getRelativeLocaleUrl(lang, '/products')} class={`nav-link nav-dropdown-link ${isActive('/products') ? 'active' : ''}`} id="nav-products">{t('nav.products')}</a>
            <div class="nav-dropdown-menu" id="products-dropdown-menu">
              {productLinks.map((item) => (
                <a href={item.href} class="nav-dropdown-item">{item.label}</a>
              ))}
            </div>
          </div>
          <a href={getRelativeLocaleUrl(lang, '/about-us')} class={`nav-link ${isActive('/about-us') ? 'active' : ''}`} id="nav-about">{t('nav.about')}</a>
          <a href={getRelativeLocaleUrl(lang, '/our-team')} class={`nav-link ${isActive('/our-team') ? 'active' : ''}`} id="nav-team">{t('nav.team')}</a>
          <a href={getRelativeLocaleUrl(lang, '/support')} class={`nav-link ${isActive('/support') ? 'active' : ''}`} id="nav-support">{t('nav.support')}</a>
          <a href={getRelativeLocaleUrl(lang, '/job-us')} class={`nav-link ${isActive('/job-us') ? 'active' : ''}`} id="nav-join">{t('nav.join')}</a>
        </nav>

        <!-- CTA Header Button & Language Selector -->
        <div class="header-cta-wrap">
          <div class="lang-selector-wrap">
            <select class="lang-selector" onchange="window.location.href=this.value" aria-label="Select Language">
              {Object.entries(languages).map(([l, name]) => (
                <option value={getRelativeLocaleUrl(l as any, cleanPathname)} selected={l === lang}>{name}</option>
              ))}
            </select>
          </div>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-sm header-cta" id="header-contact-btn">{t('nav.contact')}</a>
          
          <!-- Hamburger Button -->
          <button class="mobile-toggle" aria-label="Toggle Menu" id="menu-toggle-btn">
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
            <span class="hamburger-bar"></span>
          </button>
        </div>
      </div>
    </header>
    )}

    <!-- Mobile Navigation Drawer -->
    <div class="mobile-menu" id="mobile-menu-drawer">
      <nav class="mobile-nav-links">
        <a href={getRelativeLocaleUrl(lang, '/')} class={`mobile-nav-link ${isActive('/') ? 'active' : ''}`} id="mob-nav-home">{t('nav.home')}</a>
        <details class={`mobile-nav-group ${isActive('/projects') ? 'active' : ''}`} open={isActive('/projects')} id="mob-nav-projects-wrap">
          <summary class="mobile-nav-link mobile-nav-summary" id="mob-nav-projects">{t('nav.projects')}</summary>
          <div class="mobile-nav-submenu">
            {projectLinks.map((item) => (
              <a href={item.href} class="mobile-nav-sublink">{item.label}</a>
            ))}
          </div>
        </details>
        <details class={`mobile-nav-group ${isActive('/products') ? 'active' : ''}`} open={isActive('/products')} id="mob-nav-products-wrap">
          <summary class="mobile-nav-link mobile-nav-summary" id="mob-nav-products">{t('nav.products')}</summary>
          <div class="mobile-nav-submenu">
            {productLinks.map((item) => (
              <a href={item.href} class="mobile-nav-sublink">{item.label}</a>
            ))}
          </div>
        </details>
        <a href={getRelativeLocaleUrl(lang, '/about-us')} class={`mobile-nav-link ${isActive('/about-us') ? 'active' : ''}`} id="mob-nav-about">{t('nav.about')}</a>
        <a href={getRelativeLocaleUrl(lang, '/services')} class={`mobile-nav-link ${isActive('/services') ? 'active' : ''}`} id="mob-nav-services">{t('nav.services')}</a>
        <a href={getRelativeLocaleUrl(lang, '/our-team')} class={`mobile-nav-link ${isActive('/our-team') ? 'active' : ''}`} id="mob-nav-team">{t('nav.team')}</a>
        <a href={getRelativeLocaleUrl(lang, '/support')} class={`mobile-nav-link ${isActive('/support') ? 'active' : ''}`} id="mob-nav-support">{t('nav.support')}</a>
        <a href={getRelativeLocaleUrl(lang, '/job-us')} class={`mobile-nav-link ${isActive('/job-us') ? 'active' : ''}`} id="mob-nav-join">{t('nav.join')}</a>
        <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary mobile-menu-cta" id="mob-nav-contact">{t('nav.contact')}</a>
      </nav>
    </div>

    <!-- Main Content Slot -->
    <main class="main-content">
      <slot />
    </main>

    <!-- Footer -->
    {!hideChrome && (
    <footer class="footer">
      <div class="container footer-grid">
        <!-- Footer Column 1: Company Profile -->
        <div class="footer-col col-brand">
          <a href="/" class="logo-wrap footer-logo">
            <img src="/images/logo.png" alt="PDMS Logo" class="logo-img" />
          </a>
          <p class="footer-desc">
            Pakistan Data Management Services (PDMS) has been pioneering software development and mobile application design since 1979. We combine engineering excellence with authentic content to serve millions of users globally.
          </p>
          <div class="social-links">
            <!-- LinkedIn -->
            <a href="https://linkedin.com/company/pakdata" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
            <!-- Twitter -->
            <a href="https://twitter.com/pakdata" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
            </a>
            <!-- Facebook -->
            <a href="https://facebook.com/pakdata" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          </div>
        </div>

        <!-- Footer Column 2: Quick Links -->
        <div class="footer-col">
          <h3 class="footer-title">{t('footer.nav.title')}</h3>
          <ul class="footer-links">
            <li><a href={getRelativeLocaleUrl(lang, '/')}>{t('nav.home')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products')}>{t('nav.products')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/projects')}>{t('nav.projects')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/about-us')}>{t('nav.about')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/services')}>{t('nav.services')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/development-services')}>Development Services</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/our-team')}>{t('nav.team')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/job-us')}>{t('nav.join')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/support')}>{t('nav.support')}</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/faq')}>{t('nav.faq')}</a></li>
          </ul>
        </div>

        <!-- Footer Column 3: Top Products -->
        <div class="footer-col">
          <h3 class="footer-title">{t('footer.products.title')}</h3>
          <ul class="footer-links">
            <li><a href={getRelativeLocaleUrl(lang, '/products/quran-majeed')}>Quran Majeed App</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/quran-majeed-mac')}>Quran Majeed Mac</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/quran-pak')}>Quran Pak Reading</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/hadith-app')}>Hadith App</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/3d-salah-guide')}>3D Salah Guide</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/easyurdu')}>Easy Urdu Keyboard</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/arabicfont')}>PDMS Saleem Quran Font</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/products/kitabi')}>Kitabi</a></li>
            <li><a href="/products#quran-tv">Quran TV Streaming</a></li>
            <li><a href={getRelativeLocaleUrl(lang, '/engage-ai')}>Engage AI</a></li>
          </ul>
        </div>

        <!-- Footer Column 4: Newsletter & Inquiries -->
        <div class="footer-col">
          <h3 class="footer-title">{t('footer.connect.title')}</h3>
          <p class="footer-text">
            {t('footer.connect.desc')}
          </p>
          <form class="newsletter-form" id="newsletter-form">
            <input type="email" placeholder={t('footer.connect.placeholder')} required class="form-control newsletter-input" aria-label="Email address" />
            <button type="submit" class="btn btn-primary newsletter-btn" aria-label="Subscribe">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
          <div class="business-contact">
            <span class="contact-label">{t('footer.connect.business')}</span>
            <a href="mailto:info@pakdata.com" class="contact-value">info@pakdata.com</a>
          </div>
        </div>
      </div>

      <!-- Footer Bottom -->
      <div class="footer-bottom">
        <div class="container footer-bottom-content">
          <p>&copy; {new Date().getFullYear()} {t('footer.copyright')}</p>
          <div class="footer-bottom-links">
            <a href={getRelativeLocaleUrl(lang, '/privacy-policy')} id="footer-privacy-link">{t('footer.privacy')}</a>
            <a href={getRelativeLocaleUrl(lang, '/terms-and-conditions')} id="footer-terms-link">{t('footer.terms')}</a>
          </div>
        </div>
      </div>
    </footer>
    )}

    <!-- Interactive Navigation Scripts -->
    <script>
      const menuToggleBtn = document.getElementById('menu-toggle-btn');
      const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
      const newsletterForm = document.getElementById('newsletter-form');

      if (menuToggleBtn && mobileMenuDrawer) {
        menuToggleBtn.addEventListener('click', () => {
          menuToggleBtn.classList.toggle('active');
          mobileMenuDrawer.classList.toggle('active');
          document.body.classList.toggle('overflow-hidden');
        });

        // Close mobile drawer when link is clicked
        const mobileLinks = mobileMenuDrawer.querySelectorAll('a');
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            menuToggleBtn.classList.remove('active');
            mobileMenuDrawer.classList.remove('active');
            document.body.classList.remove('overflow-hidden');
          });
        });
      }

      if (newsletterForm) {
        newsletterForm.addEventListener('submit', (e) => {
          e.preventDefault();
          const emailInput = newsletterForm.querySelector('input');
          if (emailInput && emailInput.value) {
            alert(`Thank you for subscribing with ${emailInput.value}!`);
            emailInput.value = '';
          }
        });
      }
    </script>
  </body>
</html>

<style>
  /* Header alert bar */
  .top-bar {
    background-color: var(--dark);
    color: var(--light);
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 500;
    padding: 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .top-bar-content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }

  .top-bar-content .divider {
    color: var(--secondary);
    opacity: 0.5;
  }

  /* Header main styling */
  .header {
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 4.5rem;
  }

  /* Logo wrapper */
  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-img {
    height: auto;
    width: 10rem;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-title {
    font-family: var(--font-heading);
    font-size: calc(1.25rem * var(--text-scale, 1));
    font-weight: 800;
    color: var(--primary);
    letter-spacing: 0.02em;
  }

  .logo-subtitle {
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 500;
    color: var(--secondary-dark);
  }

  /* Desktop links */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-dropdown {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0;
    padding-bottom: .7rem;
    margin-bottom: -.7rem;
  }

  .nav-dropdown-link {
    padding-right: 0.15rem;
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + .05rem);
    left: 0;
    min-width: 13rem;
    padding: .5rem;
    border: 1px solid var(--border);
    border-radius: .75rem;
    background: rgba(255,255,255,.98);
    box-shadow: 0 20px 40px rgba(15,23,42,.12);
    z-index: 20;
    display: none;
  }

  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -.4rem;
    left: 1.15rem;
    width: .7rem;
    height: .7rem;
    transform: rotate(45deg);
    background: inherit;
    border-left: 1px solid var(--border);
    border-top: 1px solid var(--border);
  }

  .nav-dropdown-item {
    display: block;
    padding: .7rem .85rem;
    border-radius: .5rem;
    font-size: .92rem;
    font-weight: 600;
    color: var(--dark);
    white-space: nowrap;
  }

  .nav-dropdown-item:hover,
  .nav-dropdown-item:focus-visible {
    background: var(--primary-light);
    color: var(--primary);
  }

  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    display: block;
  }

  .nav-link {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark-soft);
    padding: 0.5rem 0.5rem;
    position: relative;
  }

  .nav-link:hover {
    color: var(--primary);
  }

  .nav-link.active {
    color: var(--primary);
    background-color: var(--primary-light);
    border-radius: 8px
  }

  .header-cta-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lang-selector-wrap {
    margin-right: 0.5rem;
  }
  
  :global([dir="rtl"]) .lang-selector-wrap {
    margin-right: 0;
    margin-left: 0.5rem;
  }

  .lang-selector {
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background-color: var(--light);
    color: var(--dark);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .lang-selector:focus {
    border-color: var(--primary);
  }

  .header-cta {
    display: none;
  }

  /* Mobile menu button */
  .mobile-toggle {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 1.5rem;
    height: 1.1rem;
    z-index: 110;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--dark-soft);
    border-radius: 9999px;
    transition: all var(--transition-normal);
  }

