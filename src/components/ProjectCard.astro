---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  id: string;
  title: string;
  client: string;
  description: string;
  scale: string;
  metrics: string[]; // e.g. ["99.9% Accuracy", "Instant Processing"]
  tags: string[];
  detailsUrl?: string;
}

const {
  id,
  title,
  client,
  description,
  scale,
  metrics = [],
  tags = [],
  detailsUrl = `/projects#${id}`
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="project-card" id={id}>
  <div class="project-header">
    <div class="project-title-area">
      <span class="project-client">{client}</span>
      <h3 class="project-title">{title}</h3>
    </div>
    <div class="project-scale-badge">
      <span class="scale-label">{t('project.scale.label')}</span>
      <span class="scale-value">{scale}</span>
    </div>
  </div>

  <p class="project-desc">{description}</p>

  {metrics.length > 0 && (
    <div class="project-metrics">
      {metrics.map(metric => (
        <div class="metric-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="metric-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 14 14"></polyline></svg>
          <span class="metric-text">{metric}</span>
        </div>
      ))}
    </div>
  )}

  <div class="project-footer">
    <div class="project-tags">
      {tags.map(tag => (
        <span class="project-tag">{tag}</span>
      ))}
    </div>
    {detailsUrl && (
      <a href={detailsUrl} class="project-link" aria-label={`${t('project.case.aria')} ${title}`}>
        <span>{t('project.case.label')}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    )}
  </div>
</div>

<style>
  .project-card {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-hover);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .project-title-area {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-client {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 700;
    text-transform: uppercase;
    color: var(--primary);
    letter-spacing: 0.05em;
  }

  .project-title {
    font-size: calc(1.375rem * var(--text-scale, 1));
    font-weight: 800;
    color: var(--dark);
    line-height: 1.2;
  }

  .project-scale-badge {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    background-color: var(--secondary-light);
    border: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  .scale-label {
    font-size: calc(0.625rem * var(--text-scale, 1));
    font-weight: 700;
    text-transform: uppercase;
    color: var(--secondary-dark);
  }

  .scale-value {
    font-size: calc(0.875rem * var(--text-scale, 1));
    font-weight: 800;
    color: var(--dark);
  }

  .project-desc {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.6;
    margin-bottom: 1.75rem;
    flex-grow: 1;
  }

  .project-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    padding: 1.25rem;
    background-color: var(--light-soft);
    border-radius: 0.75rem;
    margin-bottom: 1.75rem;
    border: 1px solid var(--border);
  }

  .metric-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: calc(0.8125rem * var(--text-scale, 1));
    color: var(--dark-soft);
    font-weight: 600;
  }

  .metric-icon {
    color: var(--primary);
    flex-shrink: 0;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .project-tag {
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    background-color: var(--secondary-light);
    color: var(--secondary-dark);
  }

  .project-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: calc(0.875rem * var(--text-scale, 1));
    font-weight: 700;
    color: var(--primary);
    transition: color var(--transition-fast);
  }

  .project-link:hover {
    color: var(--primary-hover);
  }

  .arrow-icon {
    transition: transform var(--transition-fast);
  }

  .project-link:hover .arrow-icon {
    transform: translateX(3px);
  }
</style>
