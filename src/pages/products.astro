---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="products-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">Our Ecosystem</span>
      <h1 class="products-hero-title">Innovative Digital Products</h1>
      <p class="products-hero-subtitle">
        We build and maintain applications that inspire spiritual connections, facilitate native communication, and solve enterprise problems.
      </p>
      
      <!-- Interactive Category Tabs -->
      <div class="tabs-wrap">
        <button class="tab-btn active" data-category="all" id="tab-all">All Products</button>
        <button class="tab-btn" data-category="islamic" id="tab-islamic">Islamic Apps</button>
        <button class="tab-btn" data-category="webtv" id="tab-webtv">Web & TV Apps</button>
        <button class="tab-btn" data-category="utility" id="tab-utility">Utilities</button>
        <button class="tab-btn" data-category="enterprise" id="tab-enterprise">Enterprise Solutions</button>
      </div>
    </div>
  </section>

  <!-- Products Showcase -->
  <section class="section">
    <div class="container">
      <div class="products-grid grid grid-2" id="products-catalog-grid">
        {products.map(product => (
          <div class="catalog-item-container" data-category={product.category}>
            <ProductCard {...product} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Optional FAQ support note -->
  <section class="section section-bg text-center">
    <div class="container max-width-600">
      <h2 class="support-prompt-title">Need Technical Help With Our Apps?</h2>
      <p class="support-prompt-desc">
        Visit our Support Center to read detailed FAQ guides on prayer alerts setup, subscription recovery, and adhan notification configurations.
      </p>
      <a href="/support" class="btn btn-outline" id="visit-support-btn">Go to Support & FAQ</a>
    </div>
  </section>

  <!-- B2B Call to Action -->
  <section class="section products-cta">
    <div class="container text-center text-white">
      <h2 class="cta-title">Looking for Enterprise Software Development?</h2>
      <p class="cta-desc">
        We have designed and deployed national databases, citizen registries, and custom AI support models. Let's build your next digital product.
      </p>
      <a href="/contact?subject=Enterprise" class="btn btn-primary btn-lg btn-white-text" id="consultation-btn">Get Free Consultation</a>
    </div>
  </section>
</Layout>

<style>
  .products-hero {
    text-align: center;
    background: radial-gradient(at 20% 0%,oklch(97% .04 60) 0%,transparent 50%),radial-gradient(at 80% 20%,oklch(96% .03 220) 0%,transparent 50%),linear-gradient(180deg,oklch(99% .005 80),oklch(100% 0 0));
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .products-hero-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .products-hero-subtitle {
    font-size: 1.25rem;
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto 3rem auto;
    line-height: 1.6;
  }

  /* Tabs */
  .tabs-wrap {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    max-width: 800px;
    margin: 0 auto;
  }

  .tab-btn {
    background-color: var(--light);
    border: 1px solid var(--border);
    color: var(--secondary-dark);
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .tab-btn:hover {
    color: var(--primary);
    border-color: var(--primary-light);
    background-color: var(--primary-light);
  }

  .tab-btn.active {
    background-color: var(--primary);
    color: var(--light);
    border-color: var(--primary);
    box-shadow: var(--shadow-primary);
  }

  /* Support prompt */
  .max-width-600 {
    max-width: 600px;
    margin: 0 auto;
  }

  .support-prompt-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .support-prompt-desc {
    color: var(--secondary-dark);
    margin-bottom: 1.5rem;
  }

  /* Products CTA styling */
  .products-cta {
    background-color: var(--dark);
    padding: 5rem 0;
  }

  .text-white {
    color: var(--light);
  }

  .text-white .cta-title {
    color: var(--light);
    font-size: 2.25rem;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .text-white .cta-desc {
    color: #9ca3af;
    max-width: 700px;
    margin: 0 auto 2.5rem auto;
    font-size: 1.125rem;
  }

  .btn-white-text {
    background-color: var(--primary);
    color: var(--light);
  }

  .btn-white-text:hover {
    background-color: var(--primary-hover);
  }

  /* Animation toggle on filter */
  .catalog-item-container {
    transition: all var(--transition-normal);
  }

  .catalog-item-container.hidden {
    opacity: 0;
    transform: scale(0.95);
    position: absolute;
    width: 0;
    height: 0;
    padding: 0;
    margin: 0;
    border: none;
    overflow: hidden;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .products-hero-title {
      font-size: 3.5rem;
    }
  }
</style>

<!-- JS Tab Filter Logic -->
<script>
  const tabButtons = document.querySelectorAll('.tab-btn');
  const catalogItems = document.querySelectorAll('.catalog-item-container');
  const catalogGrid = document.getElementById('products-catalog-grid');

  if (tabButtons.length > 0 && catalogItems.length > 0) {
    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Toggle active button
        tabButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const category = btn.getAttribute('data-category');

        // Apply grid display changes
        catalogItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category');
          
          if (category === 'all' || itemCategory === category) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });

    // Check hash parameter to auto-filter on page load
    const hash = window.location.hash;
    if (hash) {
      const targetElement = document.querySelector(hash);
      if (targetElement) {
        setTimeout(() => {
          targetElement.scrollIntoView({ behavior: 'smooth' });
        }, 100);
      }
    }
  }
</script>
