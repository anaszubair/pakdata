---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const title = "Case Studies & Projects | Pakistan Data Management Services";
const description = "Explore our large-scale software solutions: NADRA registration databases, King Fahad Quran printing tools, NARA biometric registries, and Imagine Forensic systems.";

const caseStudies = [
  {
    id: "nadra",
    title: "NADRA National Registration Platform",
    client: "NADRA, Pakistan",
    description: "Designed and engineered a high-volume registration software system capable of processing millions of National Database Forms (NDFs). The platform was optimized for secure data input, smart character recognition, and dual-script (English & Urdu) identity validation.",
    scale: "Millions of Forms",
    metrics: ["99.9% Verification Accuracy", "30% Input Speed Increase"],
    tags: ["Government", "Data Entry", "Urdu Computing"],
    challenge: "Processing massive stacks of hand-written paper application forms daily without introduction of typographical errors in names, addresses, or identifiers.",
    solution: "We built a custom visual data entry system with real-time word dictionaries, integrated Urdu keyboard mappings, and layout validators that flagged discrepancy before record commits.",
    impact: "NADRA successfully cleared backlog queues, onboarding millions of citizens into the unified database in record-breaking operational timeframes."
  },
  {
    id: "king-fahad",
    title: "King Fahad Quran Printing Support",
    client: "Saudi Arabia Collaboration",
    description: "Collaborated with Saudi Arabia's leading Quran printing complex to engineer custom typography, Arabic layout systems, and proofreading aids. This ensured the digitized Arabic text strictly adheres to classical Uthmani print styles, maintaining visual balance.",
    scale: "Global Mushaf Print",
    metrics: ["Certified Text Verification", "Millions of Prints Assisted"],
    tags: ["Arabic Scripting", "Desktop Publishing", "Verification"],
    challenge: "Digital fonts and standard typesetting software frequently distort critical Arabic vowel marks (Harakat) and letter bonds required in classical Quran printing.",
    solution: "Developed custom vector typography glyphs and a layout proofing editor that displays precise alignment of vowels on top of Arabic letters down to the sub-pixel level.",
    impact: "The Quranic text verified by our tools has been printed millions of times and distributed worldwide with 100% scriptural correctness."
  },
  {
    id: "quran-explorer",
    title: "QuranExplorer Digital Portal",
    client: "QuranExplorer Group",
    description: "Built one of the earliest and most visited web portals for Quran study. Features high-quality audio streaming of world-renowned Qaris, synced translations, side-by-side Tafsir comparisons, and bookmarks synchronization across browsers.",
    scale: "50M+ Global Visits",
    metrics: ["Synchronized Audio & Text", "Interactive Web Portal"],
    tags: ["Web Portals", "Media Streaming", "Database Search"],
    challenge: "Delivering audio streams in low-bandwidth regions while maintaining text synchronization on web browsers.",
    solution: "Designed a lightweight media player with dynamic pre-buffering and verse timestamp mappings that triggers active verse styling on scroll.",
    impact: "QuranExplorer became a benchmark in Islamic online education, helping millions of people study the Quran in 25+ language translations."
  },
  {
    id: "nara",
    title: "NARA Biometrics Registry Database",
    client: "NARA Authority, Pakistan",
    description: "Developed a secure biometric registration database and search engine for cataloging immigrant records. Integrated photo capture, fingerprint matches, and dynamic background search query engines to streamline registry management.",
    scale: "National scale",
    metrics: ["Biometric Verification", "Audit Trial Matching"],
    tags: ["Biometrics", "Identity Security", "Databases"],
    challenge: "Handling complex search queries across non-standardized foreign name spellings while preventing duplicate biometric identities.",
    solution: "Configured advanced phonetics search algorithms (Soundex adjusted for regional languages) combined with direct local biometric verification checks.",
    impact: "NARA security personnel successfully automated identity validation, reducing identity fraud margins and speeding up registration cycles."
  },
  {
    id: "imagine",
    title: "Imagine Forensic Sketching System",
    client: "Law Enforcement Agencies",
    description: "An advanced digital forensic sketching platform allowing officers to compile detailed suspect portraits based on witness descriptions. Features drag-and-drop facial modules, sizing modifiers, and background database portrait matching.",
    scale: "National Security",
    metrics: ["Rapid Portrait Creation", "Criminal Composite Library"],
    tags: ["Forensics", "Security Systems", "Graphics Canvas"],
    challenge: "Manual forensic sketches take hours to create, delay investigation trails, and require specialized artists.",
    solution: "Built a library-based sketching canvas with thousands of facial feature presets (eyes, nose, jawlines, hair) that officers can resize and adjust in real time.",
    impact: "Investigative teams compiled and shared suspect sketches with patrol units in under 20 minutes, leading to quicker search warrants."
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="projects-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">Case Studies</span>
      <h1 class="projects-hero-title">Our Projects & Case Studies</h1>
      <p class="projects-hero-subtitle">
        Discover how we have partnered with government organizations, international publishers, and enterprise brands to build systems at scale.
      </p>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="section">
    <div class="container">
      <div class="grid grid-2 project-cards-grid">
        {caseStudies.map(cs => (
          <ProjectCard {...cs} />
        ))}
      </div>
    </div>
  </section>

  <!-- Deep Dive Case Studies Details -->
  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">Technical Deep Dive</span>
        <h2 class="section-title">Case Study Details</h2>
        <p class="section-subtitle">A look into the challenges, engineering solutions, and actual impact of our key project deliveries.</p>
      </div>

      <div class="case-details-stack">
        {caseStudies.map(cs => (
          <div class="case-detail-block card" id={`details-${cs.id}`}>
            <div class="case-detail-header">
              <div>
                <span class="detail-client">{cs.client}</span>
                <h3 class="detail-title">{cs.title}</h3>
              </div>
              <span class="badge badge-success detail-scale">{cs.scale}</span>
            </div>
            
            <div class="detail-grid">
              <div class="detail-col">
                <h4 class="col-heading">The Challenge</h4>
                <p class="col-text">{cs.challenge}</p>
              </div>
              
              <div class="detail-col">
                <h4 class="col-heading">Our Solution</h4>
                <p class="col-text">{cs.solution}</p>
              </div>

              <div class="detail-col">
                <h4 class="col-heading">The Impact</h4>
                <p class="col-text">{cs.impact}</p>
              </div>
            </div>

            <div class="detail-footer">
              <div class="detail-tags">
                {cs.tags.map(tag => (
                  <span class="tag-badge">{tag}</span>
                ))}
              </div>
              <div class="detail-metrics">
                {cs.metrics.map(metric => (
                  <span class="metric-badge">{metric}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section projects-footer-cta">
    <div class="container text-center text-white">
      <h2 class="cta-title">Have a Custom Project in Mind?</h2>
      <p class="cta-desc">
        Let our decades of software engineering, custom mobile development, and systems design help your business build robust platforms.
      </p>
      <a href="/contact?subject=Project" class="btn btn-primary btn-lg btn-white-text" id="consultation-btn">Start Your Project</a>
    </div>
  </section>
</Layout>

<style>
  .projects-hero {
    background: radial-gradient(circle at 50% 50%, #fef3ec 0%, #ffffff 100%);
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .projects-hero-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .projects-hero-subtitle {
    font-size: 1.25rem;
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Deep Dive blocks */
  .case-details-stack {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 3rem;
  }

  .case-detail-block {
    border-left: 5px solid var(--primary);
    padding: 3rem;
  }

  .case-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .detail-client {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--dark);
  }

  .detail-scale {
    font-size: 0.8125rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .col-heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.75rem;
  }

  .col-text {
    font-size: 0.9375rem;
    color: var(--secondary-dark);
    line-height: 1.65;
  }

  .detail-footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .detail-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    background-color: var(--secondary-light);
    color: var(--secondary-dark);
    border-radius: 0.375rem;
  }

  .detail-metrics {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .metric-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    background-color: var(--primary-light);
    color: var(--primary);
    border: 1px solid var(--border-focus);
    border-radius: 0.375rem;
  }

  /* Projects CTA footer */
  .projects-footer-cta {
    background-color: var(--dark);
    padding: 5rem 0;
  }

  .text-white {
    color: var(--light);
  }

  .text-white .cta-title {
    color: var(--light);
    font-size: 2.25rem;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .text-white .cta-desc {
    color: #9ca3af;
    max-width: 700px;
    margin: 0 auto 2.5rem auto;
    font-size: 1.125rem;
  }

  .btn-white-text {
    background-color: var(--primary);
    color: var(--light);
  }

  .btn-white-text:hover {
    background-color: var(--primary-hover);
  }

  @media (min-width: 768px) {
    .projects-hero-title {
      font-size: 3.5rem;
    }

    .detail-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
