---

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


const title = t('contact.seo.title');
const description = t('contact.seo.desc');

const offices = [
  {
    city: t('contact.office.karachi.city'),
    address: t('contact.office.karachi.address'),
    phone: "+92-21-35882650",
    fax: "+92-21-35882651",
    email: "info@pakdata.com"
  },
  {
    city: t('contact.office.usa.city'),
    address: t('contact.office.usa.address'),
    phone: t('contact.office.usa.phone'),
    fax: t('contact.office.noFax'),
    email: "usa@pakdata.com"
  }
];

const departments = [
  {
    name: t('contact.dept.sales.name'),
    email: "info@pakdata.com",
    desc: t('contact.dept.sales.desc')
  },
  {
    name: t('contact.dept.support.name'),
    email: "support@pakdata.com",
    desc: t('contact.dept.support.desc')
  },
  {
    name: t('contact.dept.careers.name'),
    email: "careers@pakdata.com",
    desc: t('contact.dept.careers.desc')
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="contact-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">{t('contact.hero.badge')}</span>
      <h1 class="contact-hero-title">{t('contact.hero.title')}</h1>
      <p class="contact-hero-subtitle">
        {t('contact.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- Offices Grid & Contact Form -->
  <section class="section">
    <div class="container grid grid-2">
      <!-- Contact Info Column -->
      <div class="contact-info-col animate-fade-in">
        <h2 class="column-title">{t('contact.column.title')}</h2>
        <p class="column-subtitle">{t('contact.column.subtitle')}</p>
        
        <div class="offices-list">
          {offices.map(office => (
            <div class="office-card card">
              <h3 class="office-city">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span>{office.city}</span>
              </h3>
              <p class="office-address">{office.address}</p>
              
              <div class="office-details">
                <div class="detail-line">
                  <strong>{t('contact.office.phone')}</strong> <span>{office.phone}</span>
                </div>
                {office.fax !== t('contact.office.noFax') && (
                  <div class="detail-line">
                    <strong>{t('contact.office.fax')}</strong> <span>{office.fax}</span>
                  </div>
                )}
                <div class="detail-line">
                  <strong>{t('contact.office.email')}</strong> <a href={`mailto:${office.email}`}>{office.email}</a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="departments-wrap">
          <h3 class="dept-title-head">{t('contact.dept.title')}</h3>
          <div class="depts-grid">
            {departments.map(dept => (
              <div class="dept-info-box">
                <h4 class="dept-info-name">{dept.name}</h4>
                <a href={`mailto:${dept.email}`} class="dept-info-email">{dept.email}</a>
                <p class="dept-info-desc">{dept.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Contact Form Column -->
      <div class="contact-form-col animate-fade-in">
        <div class="form-container-card card">
          <h2 class="form-title">{t('contact.form.title')}</h2>
          <p class="form-subtitle">{t('contact.form.subtitle')}</p>
          
          <form class="main-contact-form" id="main-contact-form" data-alert-msg={t('contact.form.alert')}>
            <div class="form-group">
              <label class="form-label" for="contact-name">{t('contact.form.name.label')}</label>
              <input type="text" id="contact-name" required class="form-control" placeholder={t('contact.form.name.placeholder')} />
            </div>

            <div class="form-group">
              <label class="form-label" for="contact-email">{t('contact.form.email.label')}</label>
              <input type="email" id="contact-email" required class="form-control" placeholder={t('contact.form.email.placeholder')} />
            </div>

            <div class="form-group">
              <label class="form-label" for="contact-subject">{t('contact.form.subject.label')}</label>
              <select id="contact-subject" required class="form-control">
                <option value="general">{t('contact.form.subject.opt1')}</option>
                <option value="enterprise">{t('contact.form.subject.opt2')}</option>
                <option value="support">{t('contact.form.subject.opt3')}</option>
                <option value="careers">{t('contact.form.subject.opt4')}</option>
                <option value="partnership">{t('contact.form.subject.opt5')}</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="contact-msg">{t('contact.form.msg.label')}</label>
              <textarea id="contact-msg" required class="form-control" placeholder={t('contact.form.msg.placeholder')}></textarea>
            </div>

            <button type="submit" class="btn btn-primary w-100" id="submit-contact-btn">{t('contact.form.btn')}</button>
          </form>
        </div>

        <!-- Simulated Map Placeholder -->
        <div class="map-placeholder card">
          <div class="map-icon">🗺️</div>
          <div>
            <h4 class="map-title">{t('contact.map.title')}</h4>
            <p class="map-text">{t('contact.map.text')}</p>
            <a href="https://maps.google.com/?q=Pakistan+Data+Management+Services+Karachi" class="map-link" target="_blank" rel="noopener noreferrer">{t('contact.map.link')}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    text-align: center;
    background: radial-gradient(at 20% 0%,oklch(97% .04 60) 0%,transparent 50%),radial-gradient(at 80% 20%,oklch(96% .03 220) 0%,transparent 50%),linear-gradient(180deg,oklch(99% .005 80),oklch(100% 0 0));
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .contact-hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .contact-hero-subtitle {
    font-size: calc(1.25rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Info column */
  .column-title {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .column-subtitle {
    color: var(--secondary-dark);
    font-size: calc(0.9375rem * var(--text-scale, 1));
    margin-bottom: 2rem;
  }

  .offices-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .office-card {
    padding: 1.75rem;
  }

  .office-city {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .contact-icon {
    color: var(--primary);
  }

  .office-address {
    font-size: calc(0.875rem * var(--text-scale, 1));
    color: var(--dark-soft);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .office-details {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: calc(0.875rem * var(--text-scale, 1));
    border-top: 1px dashed var(--border);
    padding-top: 0.75rem;
  }

  .detail-line strong {
    color: var(--dark);
    margin-right: 0.25rem;
  }

  .detail-line a {
    color: var(--primary);
    font-weight: 600;
  }

  .departments-wrap {
    border-top: 2px solid var(--border-focus);
    padding-top: 2rem;
  }

  .dept-title-head {
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .depts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .dept-info-box {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .dept-info-name {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.15rem;
  }

  .dept-info-email {
    font-size: calc(0.875rem * var(--text-scale, 1));
    color: var(--primary);
    font-weight: 700;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .dept-info-desc {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Form column styling */
  .form-container-card {
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
    margin-bottom: 2rem;
  }

  .form-title {
    font-size: calc(1.25rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .form-subtitle {
    font-size: calc(0.875rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    margin-bottom: 2rem;
  }

  .w-100 {
    width: 100%;
  }

  /* Map card */
  .map-placeholder {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border-color: var(--border-focus);
    background-color: var(--primary-light);
  }

  .map-icon {
    font-size: calc(2.25rem * var(--text-scale, 1));
  }

  .map-title {
    font-size: calc(1rem * var(--text-scale, 1));
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 0.15rem;
  }

  .map-text {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    margin-bottom: 0.35rem;
  }

  .map-link {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 700;
    color: var(--primary);
    text-decoration: underline;
  }

  @media (min-width: 640px) {
    .contact-hero-title {
      font-size: calc(2.5rem * var(--text-scale, 1));
    }
  }

  @media (min-width: 768px) {
    .contact-hero-title {
      font-size: calc(3rem * var(--text-scale, 1));
    }
  }
</style>

<!-- Form submission script -->
<script>
  const contactForm = document.getElementById('main-contact-form');

  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertMsg = contactForm.getAttribute('data-alert-msg') || 'Message sent!';
      const submitButton = document.getElementById('submit-contact-btn') as HTMLButtonElement;

      submitButton.disabled = true;

      try {
        const response = await fetch('/api/send-email', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            formType: 'contact',
            fields: {
              name: (document.getElementById('contact-name') as HTMLInputElement)?.value,
              email: (document.getElementById('contact-email') as HTMLInputElement)?.value,
              subject: (document.getElementById('contact-subject') as HTMLSelectElement)?.value,
              message: (document.getElementById('contact-msg') as HTMLTextAreaElement)?.value
            }
          })
        });

        if (!response.ok) throw new Error('Email request failed');

        alert(alertMsg);
        contactForm.reset();
      } catch {
        alert('Sorry, your message could not be sent right now. Please try again or email us directly.');
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
