---

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


const title = t('join.seo.title');
const description = t('join.seo.desc');

const benefits = [
  {
    title: t('join.benefit.scale.title'),
    desc: t('join.benefit.scale.desc')
  },
  {
    title: t('join.benefit.purpose.title'),
    desc: t('join.benefit.purpose.desc')
  },
  {
    title: t('join.benefit.growth.title'),
    desc: t('join.benefit.growth.desc')
  },
  {
    title: t('join.benefit.workspace.title'),
    desc: t('join.benefit.workspace.desc')
  }
];

const jobs = [
  {
    id: "ios-dev",
    dept: "engineering",
    deptLabel: t('join.dept.engineering'),
    title: t('join.jobs.ios.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.khi.hybrid'),
    desc: t('join.jobs.ios.desc')
  },
  {
    id: "android-dev",
    dept: "engineering",
    deptLabel: t('join.dept.engineering'),
    title: t('join.jobs.android.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.khi.hybrid'),
    desc: t('join.jobs.android.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/seniorandroiddeveloper')
  },
  {
    id: "qa-eng",
    dept: "engineering",
    deptLabel: t('join.dept.engineering'),
    title: t('join.jobs.qa.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.khi.onsite'),
    desc: t('join.jobs.qa.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/softwarequalityassurance')
  },
  {
    id: "mkt-mgr",
    dept: "marketing",
    deptLabel: t('join.dept.marketing'),
    title: t('join.jobs.marketing.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.remote'),
    desc: t('join.jobs.marketing.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/digitalmarketingexpert')
  },
  {
    id: "support-exec",
    dept: "support",
    deptLabel: t('join.dept.support'),
    title: t('join.jobs.support.title'),
    type: t('join.job.type.shift'),
    location: t('join.job.location.khi.onsite'),
    desc: t('join.jobs.support.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/support-executive')
  },
  {
    id: "motion-des",
    dept: "creative",
    deptLabel: t('join.dept.creative'),
    title: t('join.jobs.motion.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.khi.onsite'),
    desc: t('join.jobs.motion.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/motiongraphicdesigner')
  },
  {
    id: "content-writer",
    dept: "creative",
    deptLabel: t('join.dept.creative'),
    title: t('join.jobs.writer.title'),
    type: t('join.job.type.full'),
    location: t('join.job.location.remote'),
    desc: t('join.jobs.writer.desc'),
    detailUrl: getRelativeLocaleUrl(lang, '/creativecontentwriter')
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="join-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">{t('join.hero.badge')}</span>
      <h1 class="join-hero-title">{t('join.hero.title')}</h1>
      <p class="join-hero-subtitle">
        {t('join.hero.subtitle')}
      </p>
      <div class="hero-actions">
        <a href="#openings" class="btn btn-primary btn-lg" id="view-openings-cta-btn">{t('join.hero.btn.openings')}</a>
        <a href="#benefits" class="btn btn-secondary btn-lg" id="view-benefits-cta-btn">{t('join.hero.btn.benefits')}</a>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section section-bg" id="benefits">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('join.benefits.badge')}</span>
        <h2 class="section-title">{t('join.benefits.title')}</h2>
        <p class="section-subtitle">{t('join.benefits.subtitle')}</p>
      </div>

      <div class="grid grid-2">
        {benefits.map(benefit => (
          <div class="benefit-card card">
            <h3 class="benefit-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="benefit-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{benefit.title}</span>
            </h3>
            <p class="benefit-desc">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Positions Section -->
  <section class="section" id="openings">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('join.openings.badge')}</span>
        <h2 class="section-title">{t('join.openings.title')}</h2>
        <p class="section-subtitle">{t('join.openings.subtitle')}</p>
      </div>

      <!-- Filters -->
      <div class="filter-wrap">
        <button class="filter-btn active" data-dept="all" id="filter-all">{t('join.filter.all')}</button>
        <button class="filter-btn" data-dept="engineering" id="filter-eng">{t('join.filter.engineering')}</button>
        <button class="filter-btn" data-dept="creative" id="filter-creative">{t('join.filter.creative')}</button>
        <button class="filter-btn" data-dept="marketing" id="filter-marketing">{t('join.filter.marketing')}</button>
        <button class="filter-btn" data-dept="support" id="filter-support">{t('join.filter.support')}</button>
      </div>

      <!-- Job Cards Grid -->
      <div class="jobs-list" id="jobs-catalog-list">
        {jobs.map(job => (
          <div class="job-item-container card" data-dept={job.dept}>
            <div class="job-card-header">
              <div>
                <span class="badge badge-primary job-dept-badge">{job.deptLabel}</span>
                <h3 class="job-title">{job.title}</h3>
              </div>
              <div class="job-meta-info text-right">
                <span class="job-tag job-type">{job.type}</span>
                <span class="job-tag job-location">{job.location}</span>
              </div>
            </div>
            
            <p class="job-desc">{job.desc}</p>
            
            <div class="job-actions">
              {job.detailUrl && (
                <a href={job.detailUrl} class="btn btn-outline btn-sm">{t('join.job.view')}</a>
              )}
              <button class="btn btn-outline btn-sm apply-now-trigger" data-title={job.title} data-default-title={t('join.modal.defaultPosition')} id={`apply-trigger-${job.id}`}>{t('join.job.apply')}</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Apply Form Modal Container (Simulated/Overlay) -->
  <div class="apply-modal" id="apply-modal-box">
    <div class="modal-content card">
      <button class="close-modal" id="close-modal-btn">&times;</button>
      <h3 class="modal-title">{t('join.modal.title')}</h3>
      <p class="modal-position-name" id="modal-target-position">{t('join.jobs.ios.title')}</p>
      
      <form class="apply-form" id="career-apply-form" data-alert-msg={t('join.modal.alert')} data-default-name={t('join.modal.defaultApplicant')}>
        <div class="form-group">
          <label class="form-label" for="applicant-name">{t('join.modal.name.label')}</label>
          <input type="text" id="applicant-name" required class="form-control" placeholder={t('join.modal.name.placeholder')} />
        </div>
        
        <div class="form-group">
          <label class="form-label" for="applicant-email">{t('join.modal.email.label')}</label>
          <input type="email" id="applicant-email" required class="form-control" placeholder={t('join.modal.email.placeholder')} />
        </div>

        <div class="form-group">
          <label class="form-label" for="applicant-phone">{t('join.modal.phone.label')}</label>
          <input type="tel" id="applicant-phone" required class="form-control" placeholder={t('join.modal.phone.placeholder')} />
        </div>

        <div class="form-group">
          <label class="form-label" for="applicant-resume">{t('join.modal.resume.label')}</label>
          <input type="url" id="applicant-resume" required class="form-control" placeholder={t('join.modal.resume.placeholder')} />
        </div>

        <div class="form-group">
          <label class="form-label" for="applicant-cover">{t('join.modal.cover.label')}</label>
          <textarea id="applicant-cover" class="form-control" placeholder={t('join.modal.cover.placeholder')}></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-100" id="submit-career-btn">{t('join.modal.btn')}</button>
      </form>
    </div>
  </div>

  <!-- HR Contact Info -->
  <section class="section section-bg text-center">
    <div class="container max-width-600">
      <h2 class="hr-title">{t('join.hr.title')}</h2>
      <p class="hr-desc">
        {t('join.hr.desc')}
      </p>
      <a href="mailto:careers@pakdata.com" class="btn btn-outline" id="email-hr-btn">{t('join.hr.btn')}</a>
    </div>
  </section>
</Layout>

<style>
  .join-hero {
    text-align: center;
    background: radial-gradient(at 20% 0%,oklch(97% .04 60) 0%,transparent 50%),radial-gradient(at 80% 20%,oklch(96% .03 220) 0%,transparent 50%),linear-gradient(180deg,oklch(99% .005 80),oklch(100% 0 0));
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .join-hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.2;
  }

  .join-hero-subtitle {
    font-size: calc(1.25rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto 2.5rem auto;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Benefits card */
  .benefit-card {
    padding: 2.25rem;
    border-left: 4px solid var(--primary);
  }

  .benefit-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.75rem;
  }

  .benefit-icon {
    color: var(--primary);
  }

  .benefit-desc {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Filter */
  .filter-wrap {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .filter-btn {
    background-color: var(--light);
    border: 1px solid var(--border);
    color: var(--secondary-dark);
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    font-size: calc(0.875rem * var(--text-scale, 1));
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .filter-btn:hover {
    color: var(--primary);
    background-color: var(--primary-light);
  }

  .filter-btn.active {
    background-color: var(--primary);
    color: var(--light);
    border-color: var(--primary);
    box-shadow: var(--shadow-primary);
  }

  /* Jobs List */
  .jobs-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .job-item-container {
    padding: 2rem;
    transition: all var(--transition-normal);
  }

  .job-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .job-dept-badge {
    text-transform: uppercase;
    font-size: calc(0.6875rem * var(--text-scale, 1));
    margin-bottom: 0.5rem;
  }

  .job-title {
    font-size: calc(1.25rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
  }

  .job-meta-info {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .job-tag {
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    background-color: var(--secondary-light);
    color: var(--secondary-dark);
    border: 1px solid var(--border);
  }

  .job-type {
    background-color: #ecfdf5;
    color: #047857;
    border-color: #a7f3d0;
  }

  .job-desc {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .job-item-container.hidden {
    display: none !important;
  }

  /* Modal Apply styling */
  .apply-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(17, 24, 39, 0.6);
    backdrop-filter: blur(4px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 150;
    padding: 1.5rem;
  }

  .apply-modal.active {
    display: flex;
  }

  .modal-content {
    width: 100%;
    max-width: 500px;
    position: relative;
    padding: 2.5rem;
    animation: modalSlide 0.3s ease forwards;
  }

  @keyframes modalSlide {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .close-modal {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-size: calc(2rem * var(--text-scale, 1));
    background: none;
    border: none;
    cursor: pointer;
    color: var(--secondary);
    transition: color var(--transition-fast);
  }

  .close-modal:hover {
    color: var(--primary);
  }

  .modal-title {
    font-size: calc(1.375rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .modal-position-name {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--primary);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .w-100 {
    width: 100%;
  }

  .text-right {
    text-align: right;
  }

  .max-width-600 {
    max-width: 600px;
    margin: 0 auto;
  }

  .hr-title {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .hr-desc {
    color: var(--secondary-dark);
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .join-hero-title {
      font-size: calc(2.5rem * var(--text-scale, 1));
    }
  }

  @media (min-width: 768px) {
    .join-hero-title {
      font-size: calc(3rem * var(--text-scale, 1));
    }
  }
</style>

<!-- Modal expansion scripts & filtering scripts -->
<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const jobItems = document.querySelectorAll('.job-item-container');
  const applyTriggers = document.querySelectorAll('.apply-now-trigger');
  const applyModal = document.getElementById('apply-modal-box');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const modalTargetPos = document.getElementById('modal-target-position');
  const careerApplyForm = document.getElementById('career-apply-form');

  if (filterButtons.length > 0 && jobItems.length > 0) {
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const dept = btn.getAttribute('data-dept');

        jobItems.forEach(item => {
          const itemDept = item.getAttribute('data-dept');
          if (dept === 'all' || itemDept === dept) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  }

  if (applyTriggers.length > 0 && applyModal && modalTargetPos) {
    applyTriggers.forEach(btn => {
      btn.addEventListener('click', () => {
        const jobTitle = btn.getAttribute('data-title') || btn.getAttribute('data-default-title') || '';
        modalTargetPos.textContent = jobTitle;
        applyModal.classList.add('active');
        document.body.classList.add('overflow-hidden');
      });
    });

    closeModalBtn?.addEventListener('click', () => {
      applyModal.classList.remove('active');
      document.body.classList.remove('overflow-hidden');
    });

    // Close when clicking outside of modal card
    applyModal.addEventListener('click', (e) => {
      if (e.target === applyModal) {
        applyModal.classList.remove('active');
        document.body.classList.remove('overflow-hidden');
      }
    });
  }

  if (careerApplyForm) {
    careerApplyForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const applicantName = document.getElementById('applicant-name') as HTMLInputElement;
      const defaultName = careerApplyForm.dataset.defaultName || 'Applicant';
      const alertMsg = careerApplyForm.dataset.alertMsg || '';
      const submitButton = document.getElementById('submit-career-btn') as HTMLButtonElement;

      submitButton.disabled = true;

      try {
        const response = await fetch('/api/send-email', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            formType: 'career',
            fields: {
              position: modalTargetPos?.textContent || '',
              name: applicantName?.value || defaultName,
              email: (document.getElementById('applicant-email') as HTMLInputElement)?.value,
              phone: (document.getElementById('applicant-phone') as HTMLInputElement)?.value,
              resume: (document.getElementById('applicant-resume') as HTMLInputElement)?.value,
              coverLetter: (document.getElementById('applicant-cover') as HTMLTextAreaElement)?.value
            }
          })
        });

        if (!response.ok) throw new Error('Email request failed');

        alert(`${applicantName?.value || defaultName}: ${alertMsg}`);
        applyModal?.classList.remove('active');
        document.body.classList.remove('overflow-hidden');
        careerApplyForm.reset();
      } catch {
        alert('Sorry, your application could not be sent right now. Please try again or email HR directly.');
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
