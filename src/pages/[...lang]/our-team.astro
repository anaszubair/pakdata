---

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


const title = t('team.seo.title');
const description = t('team.seo.desc');

const leaders = [
  {
    name: "Arif Hisam",
    role: t('team.leaders.arif.role'),
    bio: t('team.leaders.arif.bio'),
    avatar: "ARH"
  },
  {
    name: "Kashif Hisam",
    role: t('team.leaders.kashif.role'),
    bio: t('team.leaders.kashif.bio'),
    avatar: "KSH"
  },
  {
    name: "Asif Hisam",
    role: t('team.leaders.asif.role'),
    bio: t('team.leaders.asif.bio'),
    avatar: "ASH"
  }
];

const departments = [
  {
    name: t('team.dept.eng.name'),
    desc: t('team.dept.eng.desc')
  },
  {
    name: t('team.dept.qa.name'),
    desc: t('team.dept.qa.desc')
  },
  {
    name: t('team.dept.design.name'),
    desc: t('team.dept.design.desc')
  },
  {
    name: t('team.dept.support.name'),
    desc: t('team.dept.support.desc')
  }
];

const team = [
  {
    count: "40+",
    department: t('team.count.engineering')
  },
  {
    count: "12+",
    department: t('team.count.design')
  },
  {
    count: "15+",
    department: t('team.count.content')
  },
  {
    count: "4+",
    department: t('team.count.marketing')
  },
  {
    count: "1+",
    department: t('team.count.support')
  },
    {
    count: "6+",
    department: t('team.count.operations')
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="team-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">{t('team.hero.badge')}</span>
      <h1 class="team-hero-title">{t('team.hero.title')}</h1>
      <p class="team-hero-subtitle">
        {t('team.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- Leadership Section -->
  <section class="section">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('team.leadership.badge')}</span>
        <h2 class="section-title">{t('team.leadership.title')}</h2>
        <p class="section-subtitle">{t('team.leadership.subtitle')}</p>
      </div>

      <div class="leaders-grid grid grid-3">
        {leaders.map(leader => (
          <div class="leader-card card">
            <div class="leader-avatar-wrap">
              <div class="leader-avatar">{leader.avatar}</div>
            </div>
            <h3 class="leader-name">{leader.name}</h3>
            <span class="leader-role">{leader.role}</span>
            <p class="leader-bio">{leader.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Departments Section -->
  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('team.departments.badge')}</span>
        <h2 class="section-title">{t('team.departments.title')}</h2>
        <p class="section-subtitle">{t('team.departments.subtitle')}</p>
      </div>

      <div class="grid grid-2">
        {departments.map(dept => (
          <div class="dept-card card">
            <div class="dept-header">
              <span class="dept-icon">⚙️</span>
              <h3 class="dept-name">{dept.name}</h3>
            </div>
            <p class="dept-desc">{dept.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Culture Section -->
  <section class="section team-culture">
    <div class="container grid grid-2 align-center">
      <div class="culture-content">
        <span class="badge badge-primary">{t('team.culture.badge')}</span>
        <h2 class="culture-title">{t('team.culture.title')}</h2>
        <p class="culture-p">
          {t('team.culture.p1')}
        </p>
        <p class="culture-p">
          {t('team.culture.p2')}
        </p>
        <div class="culture-points">
          <div class="c-point">
            <strong>✓ {t('team.culture.point1.label')}</strong> {t('team.culture.point1.text')}
          </div>
          <div class="c-point">
            <strong>✓ {t('team.culture.point2.label')}</strong> {t('team.culture.point2.text')}
          </div>
          <div class="c-point">
            <strong>✓ {t('team.culture.point3.label')}</strong> {t('team.culture.point3.text')}
          </div>
        </div>
        <a href={getRelativeLocaleUrl(lang, '/job-us')} class="btn btn-primary" id="view-openings-btn">{t('team.culture.btn')}</a>
      </div>
      
      <div class="culture-visual">
        <div class="culture-quote card">
          <p class="quote-text">
            "{t('team.quote.text')}"
          </p>
          <div class="quote-author">
            <strong>Arif Hisam</strong>
            <span>{t('team.quote.authorRole')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  
  <section class="section section-bg text-center">
    <div class="container text-center">
        <div class="section-title-wrap">
          <span class="badge badge-primary">{t('team.family.badge')}</span>
          <h2 class="section-title">{t('team.family.title')}</h2>
          <p class="section-subtitle">{t('team.family.subtitle')}</p>
        </div>
      <div class="grid grid-6">
      {team.map(tm => (
        <div class="team-card card">
            <h3 class="team-count">{tm.count}</h3>
            <p class="team-department">{tm.department}</p>
        </div>
      ))}
      </div>
    </div>
  </section>

  <!-- CTA Careers -->
  <section class="section section-bg text-center">
    <div class="container max-width-600">
      <h2 class="careers-title">{t('team.join.title')}</h2>
      <p class="careers-desc">
        {t('team.join.desc')}
      </p>
      <a href={getRelativeLocaleUrl(lang, '/job-us')} class="btn btn-primary btn-lg" id="careers-cta-btn">{t('team.join.btn')}</a>
    </div>
  </section>
</Layout>

<style>
  .team-hero {
    text-align: center;
    background: radial-gradient(at 20% 0%,oklch(97% .04 60) 0%,transparent 50%),radial-gradient(at 80% 20%,oklch(96% .03 220) 0%,transparent 50%),linear-gradient(180deg,oklch(99% .005 80),oklch(100% 0 0));
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .team-hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .team-hero-subtitle {
    font-size: calc(1.25rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Leader Cards */
  .leader-card {
    text-align: center;
    padding: 2.5rem 2rem;
  }

  .leader-avatar-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .leader-avatar {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    background-color: var(--primary-light);
    color: var(--primary);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: calc(1.5rem * var(--text-scale, 1));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--border-focus);
    box-shadow: var(--shadow-sm);
  }

  .leader-name {
    font-size: calc(1.25rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.25rem;
  }

  .leader-role {
    display: block;
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 700;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .leader-bio {
    font-size: calc(0.875rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Department Cards */
  .dept-card {
    padding: 2rem;
  }

  .dept-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .dept-icon {
    font-size: calc(1.5rem * var(--text-scale, 1));
  }

  .dept-name {
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
  }

  .dept-desc {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* team-card */
  .team-card {
    text-align: center;
    padding: 1rem;
  }

  .team-count {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--primary);
  }

  .team-department {
    font-size: calc(0.75rem * var(--text-scale, 1));
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Culture Section */
  .align-center {
    align-items: center;
  }

  .culture-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .culture-title {
    font-size: calc(1.875rem * var(--text-scale, 1));
    font-weight: 600;
    line-height: 1.25;
  }

  .culture-p {
    font-size: calc(1rem * var(--text-scale, 1));
    color: var(--secondary-dark);
  }

  .culture-points {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .c-point {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--dark-soft);
  }

  .culture-visual {
    display: flex;
    justify-content: center;
  }

  .culture-quote {
    background-color: var(--light);
    border-left: 4px solid var(--primary);
    padding: 2.5rem;
    max-width: 450px;
    box-shadow: var(--shadow-lg);
  }

  .quote-text {
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-style: italic;
    line-height: 1.6;
    color: var(--dark);
    margin-bottom: 1.5rem;
  }

  .quote-author {
    display: flex;
    flex-direction: column;
  }

  .quote-author strong {
    font-size: calc(0.9375rem * var(--text-scale, 1));
    color: var(--dark);
  }

  .quote-author span {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
  }

  /* Careers cta */
  .max-width-600 {
    max-width: 600px;
    margin: 0 auto;
  }

  .careers-title {
    font-size: calc(1.75rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .careers-desc {
    color: var(--secondary-dark);
    margin-bottom: 2rem;
    font-size: calc(1rem * var(--text-scale, 1));
  }

  @media (min-width: 640px) {
    .team-hero-title {
      font-size: calc(2.5rem * var(--text-scale, 1));
    }
  }

  @media (min-width: 768px) {
    .team-hero-title {
      font-size: calc(3rem * var(--text-scale, 1));
    }
  }
</style>
