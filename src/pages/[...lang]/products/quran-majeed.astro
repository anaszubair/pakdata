    footerDesc: 'القرآن المجيد تطبيق إسلامي موثوق يقدم تلاوات القرآن والترجمات وأوقات الصلاة واتجاه القبلة والتفسير وميزات إسلامية متقدمة للمسلمين حول العالم.'
  }
}[lang];

const heroMetrics = [
  copy.trustStats[0],
  copy.trustStats[1],
  copy.trustStats[2],
  copy.trustStats[3]
];

const featureArt = [
  { src: '/images/quranmajeed/IMG_0167-768x999.png', alt: 'Quran Majeed reading screen' },
  { src: '/images/quranmajeed/IMG_0168-768x999.png', alt: 'Quran Majeed reading screen' },
  { src: '/images/quranmajeed/Quran-Majeed.png', alt: 'Quran Majeed logo' }
];

const themeImages = [
  { src: '/images/quranmajeed/Quran-Majeed.png', label: 'Reading Mode' },
  { src: '/images/quranmajeed/Frame-1-768x218.png', label: 'Toolbar' },
  { src: '/images/quranmajeed/abc2-2.png', label: 'PrayerTimes' },
  { src: '/images/quranmajeed/app3-1.png', label: 'Dark mode' },
  { src: '/images/quranmajeed/IMG_0168-768x999.png', label: 'Theme Selection' },
  { src: '/images/quranmajeed/unnamed.webp', label: 'Uthmani Font' }
];

const storeLinks = [
  { id: 'google', href: 'https://play.google.com/store/search?q=Quran%20Majeed&c=apps', label: copy.googlePlay, image: '/images/quranmajeed/Playstore.png' },
  { id: 'apple', href: 'https://apps.apple.com/us/search?term=Quran%20Majeed', label: copy.appStore, image: '/images/quranmajeed/Appstore.png' }
];
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="qm-hero">
    <div class="container qm-hero-grid">
      <div class="qm-hero-copy">
        <span class="badge badge-primary qm-eyebrow">{copy.heroBadge}</span>
        <h1 class="qm-title">{copy.heroTitle}</h1>
        <p class="qm-lead">{copy.heroLead}</p>
        <p class="qm-body">{copy.heroBody}</p>

        <div class="qm-trust-strip" aria-label="Quran Majeed highlights">
          <span class="qm-trust-item">4.8★</span>
          <span class="qm-trust-item">50M+ downloads</span>
          <span class="qm-trust-item">Prayer times</span>
          <span class="qm-trust-item">Audio recitations</span>
        </div>

        <div class="qm-cta-row">
          {storeLinks.map(link => (
            <a href={link.href} class="store-btn" target="_blank" rel="noopener noreferrer">
              <img src={link.image} alt={link.label} class="store-badge" />
              <span>{link.label}</span>
            </a>
          ))}
          <a href="#features" class="btn btn-outline qm-explore-btn">{copy.explore}</a>
        </div>

        <div class="qm-proof-row">
          <div class="qm-proof-pill">4.8★</div>
          <div class="qm-proof-pill">50M+</div>
          <div class="qm-proof-pill">45+ Languages</div>
          <div class="qm-proof-pill">Offline Reading</div>
        </div>
      </div>

      <aside class="qm-showcase">
        <div class="qm-showcase-shell card">
          <div class="qm-showcase-top">
            <div class="qm-showcase-brand">
              <img src="/images/quranmajeed/QM.png" alt="Quran Majeed logo" class="brand-logo" />
              <div>
                <p class="download-card-label">{copy.trustTitle}</p>
                <h2 class="download-card-title">4.8★</h2>
              </div>
            </div>
            <div class="qm-showcase-badge">Trusted & modern</div>
          </div>

          <div class="qm-showcase-hero">
            <img src="/images/quranmajeed/IMG_0167-768x999.png" alt="Quran Majeed screenshot" class="qm-shot-main" />
            <div class="qm-shot-stack">
              <img src="/images/quranmajeed/IMG_0168-768x999.png" alt="Quran Majeed screenshot" />
              <img src="/images/quranmajeed/Quran-Majeed.png" alt="Quran Majeed logo artwork" />
            </div>
          </div>

          <div class="download-card-stats">
            {heroMetrics.map(metric => <div class="download-stat">{metric}</div>)}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section qm-trust">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.trustTitle}</span>
        <h2 class="section-title">{copy.trustTitle}</h2>
      </div>
      <div class="trust-grid">
        {copy.trustStats.map(stat => (
          <div class="trust-card card">
            <div class="trust-dot"></div>
            <p>{stat}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Features</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>
      <div class="feature-grid">
        {copy.featureCards.map((feature, idx) => (
          <article class="feature-card card">
            <div class="feature-index">0{idx + 1}</div>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-grid">
      <div class="media-stack">
        <img src={featureArt[0].src} alt={featureArt[0].alt} class="stack-shot large" />
        <img src={featureArt[1].src} alt={featureArt[1].alt} class="stack-shot small" />
      </div>
      <div class="split-copy">
        <span class="badge badge-primary">Reading</span>
        <h2 class="section-title">{copy.readingTitle}</h2>
        <p class="body-copy">{copy.readingBody1}</p>
        <p class="body-copy">{copy.readingBody2}</p>
        <div class="feature-mini-list">
          <div class="mini-item">Authentic script</div>
          <div class="mini-item">Smooth page flow</div>
          <div class="mini-item">Quiet reading mode</div>
          <div class="mini-item">Custom text sizes</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid reverse">
      <div class="split-copy">
        <span class="badge badge-primary">Themes</span>
        <h2 class="section-title">{copy.themesTitle}</h2>
        <p class="body-copy">{copy.themesBody}</p>
        <div class="feature-mini-list">
          <div class="mini-item">Night mode</div>
          <div class="mini-item">Classic and modern themes</div>
          <div class="mini-item">Adjustable spacing</div>
          <div class="mini-item">Accessibility tools</div>
        </div>
      </div>
      <div class="theme-grid">
        {themeImages.map(image => (
          <figure class="theme-card card">
            <img src={image.src} alt={image.label} />
            <figcaption>{image.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Salient</span>
        <h2 class="section-title">{copy.salientTitle}</h2>
      </div>
      <div class="salient-grid">
        {copy.salientItems.map(item => <div class="salient-item">{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section productivity-band">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">Every Day</span>
        <h2 class="section-title">{copy.dailyTitle}</h2>
        <p class="body-copy">{copy.dailyBody}</p>
      </div>
      <div class="daily-panel card">
        <img src="/images/quranmajeed/serveWithUsBanner.89d658ef-1536x582.webp" alt="Quran Majeed banner" />
        <div class="daily-panel-copy">
          <p>Prayer timings</p>
          <p>Qibla direction</p>
          <p>Tafsir study</p>
          <p>Audio recitations</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid reverse">
      <div class="video-card card">
        <img src="/images/quranmajeed/Frame-1-768x218.png" alt="Video guide preview" />
        <div class="play-chip">▶</div>
      </div>
      <div class="split-copy">
        <span class="badge badge-primary">Video</span>
        <h2 class="section-title">{copy.videoTitle}</h2>
        <p class="body-copy">{copy.videoBody}</p>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Reviews</span>
        <h2 class="section-title">{copy.reviewsTitle}</h2>
      </div>
      <div class="review-grid">
        {copy.reviews.map(review => (
          <article class="review-card card">
            <p class="review-quote">“{review.quote}”</p>
            <div class="review-meta">
              <strong>{review.name}</strong>
              <span>{review.meta}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container faq-wrap">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">FAQ</span>
        <h2 class="section-title">{copy.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {copy.faqs.map((faq, idx) => (
          <details class="faq-item card" open={idx === 0}>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta-band">
    <div class="container final-cta-grid">
      <div>
        <span class="badge badge-primary">{copy.finalBadge}</span>
        <h2 class="section-title">{copy.finalTitle}</h2>
        <p class="body-copy">{copy.finalBody1}</p>
        <p class="body-copy">{copy.finalBody2}</p>
        <div class="qm-cta-row">
          {storeLinks.map(link => (
            <a href={link.href} class="store-btn dark" target="_blank" rel="noopener noreferrer">
              <img src={link.image} alt={link.label} class="store-badge" />
              <span>{link.id === 'google' ? copy.finalGoogle : copy.finalAppStore}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="final-art card">
        <img src="/images/quranmajeed/Quran-Majeed.png" alt="Quran Majeed logo" />
        <p>{copy.footerDesc}</p>
      </div>
    </div>
  </section>

  <section class="section footer-summary">
    <div class="container">
      <p>{copy.footerDesc}</p>
    </div>
  </section>
</Layout>

<style>
  .qm-hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 4.5rem);
    display: flex;
    align-items: center;
    padding: 2.5rem 0 2rem;
    background:
      linear-gradient(135deg, rgba(255,251,245,.97), rgba(255,244,232,.94)),
      url('/images/quranmajeed/bg-18-Copy-Copy.jpg') center/cover no-repeat;
  }

  .qm-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, rgba(255,255,255,.76), transparent 44%),
      linear-gradient(0deg, rgba(255,255,255,.14), rgba(255,255,255,.14));
    pointer-events: none;
  }

  .qm-hero-grid,
  .split-grid,
  .final-cta-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .qm-hero-grid {
    position: relative;
    z-index: 1;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
    gap: 1.5rem;
  }

  .qm-hero-copy {
    max-width: 44rem;
  }

  .qm-eyebrow,
  .badge {
    margin-bottom: 1rem;
  }

  .qm-eyebrow {
    box-shadow: 0 8px 24px rgba(249,115,22,.08);
  }

  .qm-title {
    font-size: clamp(1.85rem, 2.5vw, 2.95rem);
    line-height: 1.05;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--primary);
  }

  .qm-lead {
    font-size: clamp(.98rem, 1.15vw, 1.08rem);
    line-height: 1.55;
    margin-bottom: 1rem;
    color: var(--dark);
    max-width: 38rem;
  }

  .qm-body,
  .body-copy {
    color: var(--secondary-dark);
    line-height: 1.55;
    font-size: .96rem;
    max-width: 38rem;
  }

  .qm-trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-top: .95rem;
  }

  .qm-trust-item {
    padding: .42rem .72rem;
    border-radius: 999px;
    border: 1px solid rgba(249,115,22,.16);
    background: rgba(255,255,255,.78);
    color: var(--dark);
    font-size: .84rem;
    font-weight: 700;
    box-shadow: 0 8px 20px rgba(15,23,42,.05);
  }

  .qm-cta-row {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    margin-top: 1.1rem;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    padding: .8rem 1rem;
    border-radius: .8rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,.92);
    color: var(--dark);
    font-weight: 600;
  }

  .store-btn.dark {
    background: rgba(17,24,39,.08);
  }

  .store-badge {
    width: 1.35rem;
    height: 1.35rem;
    object-fit: contain;
  }

  .qm-explore-btn {
    align-self: center;
  }

  .qm-proof-row {
    display: flex;
    gap: .65rem;
    flex-wrap: wrap;
    margin-top: .9rem;
  }

  .qm-proof-pill {
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(249,115,22,.12);
    border-radius: 999px;
    padding: .55rem .9rem;
    font-size: .9rem;
    font-weight: 600;
    box-shadow: 0 8px 18px rgba(15,23,42,.05);
  }

  .qm-showcase {
    position: relative;
  }

  .qm-showcase-shell {
    position: sticky;
    top: 5.6rem;
    padding: 1rem;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(255,250,244,.94));
    border: 1px solid rgba(249,115,22,.12);
    box-shadow: 0 24px 50px rgba(15,23,42,.1);
  }

  .qm-showcase-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: .85rem;
  }

  .qm-showcase-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand-logo {
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 1rem;
    object-fit: cover;
    box-shadow: 0 12px 28px rgba(15,23,42,.08);
  }

  .download-card-label {
    font-size: .8rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--secondary-dark);
    margin-bottom: .25rem;
  }

  .download-card-title {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    margin: 0;
  }

  .qm-showcase-badge {
    align-self: flex-start;
    padding: .45rem .75rem;
    border-radius: 999px;
    background: rgba(249,115,22,.11);
    color: var(--primary);
    font-size: .82rem;
    font-weight: 700;
  }

  .download-card-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .65rem;
    margin-bottom: 1rem;
  }

  .download-stat {
    border-radius: .75rem;
    background: rgba(255,255,255,.92);
    border: 1px solid rgba(249,115,22,.12);
    padding: .85rem;
    font-size: .875rem;
    line-height: 1.4;
  }

  .qm-showcase-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(160px, .82fr);
    gap: .7rem;
    margin: .85rem 0;
  }

  .qm-shot-main,
  .qm-shot-stack img {
    width: 100%;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid rgba(249,115,22,.12);
    background: #fff;
    box-shadow: 0 14px 30px rgba(15,23,42,.08);
  }

  .qm-shot-main {
    height: 17rem;
    object-fit: contain;
    padding: .7rem;
    background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,247,238,.94));
  }

  .qm-shot-stack {
    display: grid;
    gap: .65rem;
  }

  .qm-shot-stack img {
    height: 8rem;
    object-fit: cover;
  }

  .qm-trust .trust-grid,
  .feature-grid,
  .review-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .trust-card,
  .feature-card,
  .review-card,
  .theme-card,
  .daily-panel,
  .video-card,
  .final-art,
  .faq-item {
    border-radius: 1rem;
    padding: 1.25rem;
  }

  .trust-card {
    display: flex;
    gap: .75rem;
    align-items: flex-start;
  }

  .trust-dot {
    width: .75rem;
    height: .75rem;
    border-radius: 50%;
    background: var(--primary);
    flex: 0 0 auto;
    margin-top: .35rem;
  }

  .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card h3 {
    font-size: 1.15rem;
    margin-bottom: .65rem;
  }

  .feature-card p {
    color: var(--secondary-dark);
    line-height: 1.65;
  }

  .feature-index {
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--primary);
    margin-bottom: .75rem;
    font-weight: 700;
  }

  .split-grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .split-grid.reverse .media-stack,
  .split-grid.reverse .theme-grid {
    order: 2;
  }

  .media-stack {
    position: relative;
    min-height: 42rem;
  }

  .stack-shot {
    position: absolute;
    border-radius: 1.25rem;
    object-fit: cover;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
    background: #fff;
  }

  .stack-shot.large {
    width: 72%;
    left: 0;
    top: 0;
  }

  .stack-shot.small {
    width: 58%;
    right: 0;
    bottom: 0;
  }

  .feature-mini-list {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
    margin-top: 1.25rem;
  }

  .mini-item,
  .salient-item {
    background: var(--light-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: .6rem .9rem;
    font-size: .9rem;
    font-weight: 600;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .theme-card img,
  .daily-panel img,
  .video-card img,
  .final-art img {
    width: 100%;
    display: block;
    border-radius: .75rem;
    object-fit: cover;
  }

  .theme-card img {
    height: 9.5rem;
  }

  .theme-card figcaption {
    margin-top: .75rem;
    font-size: .9rem;
    font-weight: 600;
    color: var(--secondary-dark);
  }

  .salient-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .productivity-band,
  .final-cta-band {
    background: linear-gradient(180deg, #fff, #fdf8f0);
  }

  .daily-panel {
    background: var(--light);
  }

  .daily-panel-copy {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .75rem;
    margin-top: 1rem;
  }

  .daily-panel-copy p {
    background: var(--light-soft);
    border: 1px solid var(--border);
    border-radius: .75rem;
    padding: .75rem;
    font-weight: 600;
  }

  .video-card {
    position: relative;
    overflow: hidden;
    padding: 0;
  }

  .video-card img {
    height: 18rem;
    object-fit: cover;
  }

  .play-chip {
    position: absolute;
    inset: auto auto 1rem 1rem;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    background: rgba(17,24,39,.88);
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 700;
  }

  .review-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .review-quote {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
    gap: .15rem;
    color: var(--secondary-dark);
  }

  .faq-wrap {
    max-width: 56rem;
  }

  .faq-list {
    display: grid;
    gap: .75rem;
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    margin-top: .75rem;
    color: var(--secondary-dark);
    line-height: 1.7;
  }

  .final-cta-grid {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, .85fr);
  }

  .final-art {
    text-align: center;
  }

  .final-art img {
    max-width: 10rem;
    margin: 0 auto 1rem;
    object-fit: contain;
  }

  .footer-summary {
    padding-top: 0;
  }

  .footer-summary p {
    max-width: 60rem;
    margin: 0 auto;
    text-align: center;
    color: var(--secondary-dark);
    line-height: 1.7;
  }

  .tight {
    margin-bottom: 1.5rem;
  }

  @media (max-width: 1024px) {
    .qm-hero-grid,
    .split-grid,
    .final-cta-grid {
      grid-template-columns: 1fr;
    }

    .qm-showcase-shell {
      position: static;
