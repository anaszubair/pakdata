            <span>{copy.appStore}</span>
          </a>
          <a href="#features" class="btn btn-secondary">{copy.finalLearn}</a>
        </div>
      </div>
      <aside class="hadith-final-card card">
        <img src="/images/hadith/logo-hadith.webp" alt="Hadith app logo" class="hadith-final-logo" />
        <p>{copy.footerDesc}</p>
      </aside>
    </div>
  </section>

  <section class="section footer-summary">
    <div class="container">
      <p>{copy.footerDesc}</p>
    </div>
  </section>
</Layout>

