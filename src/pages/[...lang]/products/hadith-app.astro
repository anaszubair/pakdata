            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section hadith-final-band">
    <div class="container hadith-final-grid">
      <div class="hadith-section-copy">
        <span class="badge badge-primary">{copy.finalBadge}</span>
