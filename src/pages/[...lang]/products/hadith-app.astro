        {copy.reviews.map(review => (
          <article class="hadith-review-card card">
            <p class="review-quote">“{review.quote}”</p>
            <div class="review-meta">
              <strong>{review.name}</strong>
              <span>{review.meta}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section hadith-faq-band">
    <div class="container hadith-faq-wrap">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">FAQ</span>
        <h2 class="section-title">{copy.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {copy.faqs.map((faq, idx) => (
          <details class="faq-item card" open={idx === 0}>
