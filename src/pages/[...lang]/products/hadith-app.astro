const hadithScreens = [
  { src: '/images/hadith/logo-hadith.webp', alt: 'Hadith app logo and books' },
  { src: '/images/hadith/unnamed.webp', alt: 'Hadith app reading screen' },
  { src: '/images/hadith/unnamed (1).webp', alt: 'Hadith app search screen' },
  { src: '/images/hadith/unnamed (2).webp', alt: 'Hadith app themes screen' },
  { src: '/images/hadith/unnamed (7).webp', alt: 'Hadith app collections screen' }
];

const storeLink = {
  href: 'https://apps.apple.com/us/search?term=Hadith',
  image: '/images/quranmajeed/Appstore.png'
};
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="hadith-hero">
    <div class="container hadith-hero-grid">
      <div class="hadith-copy">
        <span class="badge badge-primary hadith-badge">{copy.heroBadge}</span>
        <h1 class="hadith-title">
          <span class="hadith-title-text">{copy.heroTitle}</span>
          <span class="hadith-title-honorific" aria-label="peace be upon him">{copy.heroHonorific}</span>
        </h1>
        <p class="hadith-lead">{copy.heroLead}</p>
        <p class="hadith-body">{copy.heroBody}</p>

        <div class="hadith-feature-bar" aria-label="Hadith highlights">
          {copy.featureBar.map(item => <span class="hadith-chip">{item}</span>)}
        </div>

        <div class="hadith-cta-row">
          <a href={storeLink.href} class="store-btn" target="_blank" rel="noopener noreferrer">
            <img src={storeLink.image} alt={copy.appStore} class="store-badge" />
            <span>{copy.appStore}</span>
          </a>
          <a href="#features" class="btn btn-outline hadith-explore">{copy.explore}</a>
        </div>
      </div>

      <aside class="hadith-showcase">
        <div class="hadith-showcase-shell card">
          <div class="hadith-showcase-top">
            <div class="hadith-brand">
              <img src="/images/hadith/logo-hadith.webp" alt="Hadith app logo" class="hadith-brand-logo" />
              <div>
                <p class="hadith-label">{copy.introTitle}</p>
                <h2 class="hadith-rating">4.8★</h2>
              </div>
            </div>
            <div class="hadith-badge-pill">Authentic collections</div>
          </div>

          <div class="hadith-showcase-hero">
            <img src={hadithScreens[1].src} alt={hadithScreens[1].alt} class="hadith-main-shot" />
            <div class="hadith-shot-stack">
              <img src={hadithScreens[2].src} alt={hadithScreens[2].alt} />
              <img src={hadithScreens[3].src} alt={hadithScreens[3].alt} />
            </div>
          </div>

          <div class="hadith-stat-grid">
            <div class="hadith-stat">Sahih Bukhari</div>
            <div class="hadith-stat">Arabic text</div>
            <div class="hadith-stat">Bookmarks</div>
            <div class="hadith-stat">Advanced search</div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section hadith-intro">
    <div class="container hadith-split">
      <div class="hadith-section-copy">
        <span class="badge badge-primary">Introduction</span>
