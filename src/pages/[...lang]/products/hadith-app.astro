    </div>
  </section>

  <section class="section hadith-why-band">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Trust</span>
        <h2 class="section-title">{copy.whyTitle}</h2>
      </div>
      <div class="hadith-why-grid">
        {copy.why.map(item => (
          <article class="hadith-why-card card">
            <div class="why-icon">✦</div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section hadith-reviews-band">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Reviews</span>
        <h2 class="section-title">{copy.reviewsTitle}</h2>
      </div>
