---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="easy-hero">
    <div class="container easy-hero-grid">
      <div class="easy-copy">
        <span class="badge badge-primary easy-badge">{copy.heroBadge}</span>
        <h1 class="easy-title">{copy.heroTitle}</h1>
        <p class="easy-lead">{copy.heroLead}</p>
        <p class="easy-body">{copy.heroBody}</p>

        <div class="easy-feature-bar" aria-label="Easy Sindhi highlights">
          {copy.featureBar.map(item => <span class="easy-chip">{item}</span>)}
        </div>

        <div class="easy-cta-row">
          <a href={storeLink.href} class="store-btn" target="_blank" rel="noopener noreferrer">
            <img src={storeLink.image} alt={copy.download} class="store-badge" />
            <span>{copy.download}</span>
          </a>
          <a href="#features" class="btn btn-outline easy-explore">{copy.explore}</a>
        </div>
      </div>

      <aside class="easy-showcase">
        <div class="easy-showcase-shell card">
          <div class="easy-showcase-top">
            <div class="easy-brand">
              <img src="/images/easysindhi/easysindhi.png" alt="Easy Sindhi Keyboard logo" class="easy-brand-logo" />
              <div>
                <p class="easy-label">{copy.heroBadge}</p>
                <h2 class="easy-rating">4.8★</h2>
              </div>
            </div>
            <div class="easy-badge-pill">Sindhi typing made easy</div>
          </div>

          <div class="easy-showcase-hero">
            <img src={screenshots[1].src} alt={screenshots[1].alt} class="easy-main-shot" />
            <div class="easy-shot-stack">
              <img src={screenshots[2].src} alt={screenshots[2].alt} />
              <img src={screenshots[3].src} alt={screenshots[3].alt} />
            </div>
          </div>

          <div class="easy-stat-grid">
            <div class="easy-stat">Roman to Sindhi</div>
            <div class="easy-stat">Voice typing</div>
            <div class="easy-stat">Smart suggestions</div>
            <div class="easy-stat">Custom themes</div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section easy-intro">
    <div class="container easy-split">
      <div class="easy-section-copy">
        <span class="badge badge-primary">Introduction</span>
        <h2 class="section-title">{copy.introTitle}</h2>
        <p class="section-body">{copy.introBody1}</p>
        <p class="section-body">{copy.introBody2}</p>
      </div>
      <div class="easy-how-card card">
        <span class="badge badge-primary">{copy.howTitle}</span>
        <div class="how-steps">
