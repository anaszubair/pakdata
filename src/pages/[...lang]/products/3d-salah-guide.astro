<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="salah-hero">
    <div class="container salah-hero-grid">
      <div class="salah-copy">
        <span class="badge badge-primary salah-badge">{copy.heroBadge}</span>
        <h1 class="salah-title">{copy.heroTitle}</h1>
        <p class="salah-lead">{copy.heroLead}</p>
        <p class="salah-body">{copy.heroBody}</p>

        <div class="salah-feature-bar" aria-label="Salah highlights">
          {copy.featureBar.map(item => <span class="salah-chip">{item}</span>)}
        </div>

        <div class="salah-cta-row">
          <a href={storeLink.href} class="store-btn" target="_blank" rel="noopener noreferrer">
            <img src={storeLink.image} alt={copy.appStore} class="store-badge" />
            <span>{copy.appStore}</span>
          </a>
          <a href="#features" class="btn btn-outline salah-explore">{copy.explore}</a>
        </div>
      </div>

      <aside class="salah-showcase">
