---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="font-hero">
    <div class="container font-grid">
      <div class="font-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="font-title">{copy.heroTitle}</h1>
        <p class="font-lead">{copy.heroLead}</p>
        <p class="font-support">{copy.heroSupport}</p>

        <div class="font-actions">
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-primary btn-lg">{copy.explore}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.contact}</a>
        </div>
      </div>

      <div class="font-preview card">
        <div class="specimen-head">
          <span>PDMS Saleem Quran Font</span>
          <strong>OpenType / Unicode</strong>
        </div>
        <div class="specimen-box">
          <div class="specimen-main">ٱلْقُرْآنُ</div>
          <div class="specimen-sub">Arabic font crafted for Quran text</div>
        </div>
        <div class="specimen-footer">
          <span>Waqf symbols</span>
          <span>Aeraab support</span>
          <span>Calligraphic quality</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-grid card">
        <div class="info-row">
          <span class="info-kicker">Format</span>
          <strong>OpenType / Unicode</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Focus</span>
          <strong>Holy Quran text</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Style</span>
          <strong>Quranic calligraphy inspired</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.craftTitle}</span>
        <h2 class="section-title">{copy.craftTitle}</h2>
        <p class="body-copy">{copy.craftBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Font features</h3>
        <ul class="check-list">
          {copy.features.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.typographyTitle}</span>
        <h2 class="section-title">{copy.typographyTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.typographyBody}</p>
      <div class="chip-row">
        {copy.typographyChips.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.aboutTitle}</span>
        <h2 class="section-title">{copy.aboutTitle}</h2>
        <p class="body-copy">{copy.aboutBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">PDMS product legacy</h3>
        <ul class="check-list">
          <li>Nastaleeq Nizami</li>
          <li>Urdu Computer Nizam</li>
          <li>Ruqqa-UrduEmail</li>
          <li>Urdu 98 and Urdu Mahir</li>
          <li>PDMS Jauhar and Quran Majeed CD</li>
          <li>Regional fonts and Urdu portals</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.impactTitle}</span>
        <h2 class="section-title">{copy.impactTitle}</h2>
        <p class="body-copy">{copy.impactBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Why it matters</h3>
        <ul class="check-list">
          {copy.impactItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section font-cta">
    <div class="container text-center text-white">
      <h2 class="cta-title">{copy.finalTitle}</h2>
      <p class="cta-desc">{copy.finalBody}</p>
      <div class="cta-actions">
        <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-primary btn-lg btn-white-text">{copy.explore}</a>
        <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg btn-white-text">{copy.contact}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .font-hero {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, #fefbf8, #fff);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 4rem;
  }

  .font-grid,
  .split-layout {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 2rem;
    align-items: center;
  }

  .split-layout.reverse {
    grid-template-columns: .95fr 1.05fr;
  }

  .font-title {
    font-size: clamp(1.8rem, 2.5vw, 3rem);
    line-height: 1.05;
    font-weight: 700;
    color: var(--primary);
    margin: .9rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .font-lead,
  .font-support,
  .body-copy {
    color: var(--secondary-dark);
    line-height: 1.7;
    font-size: calc(1.02rem * var(--text-scale, 1));
  }

  .font-support {
    margin-top: .9rem;
    font-weight: 600;
    color: var(--dark);
  }

  .font-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    margin-top: 1.3rem;
  }

  .font-preview,
  .info-grid,
  .list-panel {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1.2rem;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .font-preview {
    padding: 1.2rem;
