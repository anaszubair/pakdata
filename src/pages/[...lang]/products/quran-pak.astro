    finalBadge: 'ابدأ اليوم',
    finalTitle: 'قوِّ صلتك بالقرآن',
    finalBody1: 'انضم إلى آلاف المستخدمين الذين يثقون بالقرآن باك للتلاوة القرآنية الأصيلة والترجمات الأردية والتفسير والتعلّم الإسلامي الهادف.',
    finalBody2: 'حمّل القرآن باك اليوم واستمتع بمرافق قرآني مصمم بشكل جميل للنمو الروحي اليومي.',
    finalAppStore: 'حمّل من App Store',
    finalLearn: 'اعرف المزيد',
    footerDesc: 'القرآن باك تطبيق غني بالميزات يقدم ترجمات أردية، وتفسير عثماني، وتلاوات متقدمة، وأدوات قوية لدراسة القرآن للمسلمين حول العالم.'
  }
}[lang];

const heroScreens = [
  { src: '/images/quranpak/unnamed.webp', alt: 'Quran Pak featured screen' },
  { src: '/images/quranpak/unnamed (1).webp', alt: 'Quran Pak reading screen' },
  { src: '/images/quranpak/unnamed (2).webp', alt: 'Quran Pak study screen' },
  { src: '/images/quranpak/app3-1.webp', alt: 'Quran Pak prayer screen' }
];

const galleryScreens = [
  '/images/quranpak/unnamed (3).webp',
  '/images/quranpak/unnamed (4).webp',
  '/images/quranpak/unnamed (5).webp',
  '/images/quranpak/unnamed (6).webp',
  '/images/quranpak/app3-1.webp'
];

const storeBadge = '/images/quranmajeed/Appstore.png';
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class={`qp-hero ${isRtl ? 'rtl' : ''}`}>
    <div class="container qp-hero-grid">
      <div class="qp-copy">
        <span class="badge badge-primary qp-badge">{copy.heroBadge}</span>
        <h1 class="qp-title">{copy.heroTitle}</h1>
        <p class="qp-lead">{copy.heroLead}</p>
        <p class="qp-body">{copy.heroBody}</p>

        <div class="qp-trust-strip" aria-label="Quran Pak highlights">
          {copy.stats.map((item) => <span class="qp-trust-item">{item}</span>)}
        </div>

        <div class="qp-cta-row">
          <a href="https://apps.apple.com/us/search?term=Quran%20Pak" class="store-btn" target="_blank" rel="noopener noreferrer">
            <img src={storeBadge} alt={copy.appStore} class="store-badge" />
            <span>{copy.appStore}</span>
          </a>
          <a href="#features" class="btn btn-outline qp-explore">{copy.explore}</a>
        </div>

        <div class="highlight-bar" aria-label="Quran Pak highlights">
          {copy.highlights.map(item => <span class="highlight-pill">{item}</span>)}
        </div>
      </div>

      <aside class="qp-showcase">
        <div class="qp-showcase-shell card">
          <div class="qp-showcase-top">
            <div class="qp-showcase-brand">
              <img src="/images/QP.webp" alt="Quran Pak logo" class="qp-brand-logo" />
              <div>
                <p class="qp-download-card-label">{copy.statsTitle}</p>
                <h2 class="qp-download-card-title">4.9★</h2>
              </div>
            </div>
            <div class="qp-showcase-badge">Urdu-first reading</div>
          </div>

          <div class="qp-showcase-hero">
            <img src={heroScreens[0].src} alt={heroScreens[0].alt} class="qp-shot-main" />
            <div class="qp-shot-stack">
              <img src={heroScreens[1].src} alt={heroScreens[1].alt} />
              <img src={heroScreens[2].src} alt={heroScreens[2].alt} />
            </div>
          </div>

          <div class="qp-download-card-stats">
            <div class="qp-download-stat">Tafsir Usmani</div>
            <div class="qp-download-stat">Urdu translations</div>
            <div class="qp-download-stat">Audio recitations</div>
            <div class="qp-download-stat">Bookmarks</div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section qp-section-intro">
    <div class="container qp-split">
      <div class="qp-section-copy">
        <span class="badge badge-primary">Introduction</span>
        <h2 class="section-title">{copy.introTitle}</h2>
        <p class="section-body">{copy.introBody1}</p>
        <p class="section-body">{copy.introBody2}</p>
      </div>
      <div class="qp-stat-stack">
        <div class="section-title-wrap tight">
          <span class="badge badge-primary">{copy.statsTitle}</span>
        </div>
        <div class="stat-grid">
          {copy.stats.map(stat => (
            <div class="stat-card card">
              <span class="stat-dot"></span>
              <p>{stat}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section qp-section-features" id="features">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Features</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>
      <div class="feature-grid">
        {copy.features.map((feature, idx) => (
          <article class="feature-card card">
            <div class="feature-index">0{idx + 1}</div>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section qp-reading-band">
    <div class="container qp-media-grid">
      <div class="qp-media-copy">
        <span class="badge badge-primary">Reading</span>
        <h2 class="section-title">{copy.readingTitle}</h2>
        <p class="section-body">{copy.readingBody}</p>
        <div class="mini-grid">
          <div class="mini-card">Authentic Urdu script</div>
          <div class="mini-card">Smooth navigation</div>
          <div class="mini-card">Comfortable text layout</div>
          <div class="mini-card">Daily reflection mode</div>
        </div>
      </div>
      <div class="screenshot-carousel" aria-label="Quran Pak screenshots">
        <img src={heroScreens[1].src} alt={heroScreens[1].alt} />
        <img src={heroScreens[2].src} alt={heroScreens[2].alt} />
        <img src={heroScreens[3].src} alt={heroScreens[3].alt} />
        {galleryScreens.map((src, idx) => (
          <img src={src} alt={`Quran Pak screenshot ${idx + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <section class="section qp-learn-band">
    <div class="container qp-split reverse">
      <div class="qp-section-copy">
        <span class="badge badge-primary">Learning</span>
        <h2 class="section-title">{copy.learningTitle}</h2>
        <p class="section-body">{copy.learningBody}</p>
      </div>
      <div class="why-grid">
        {copy.why.map(item => (
          <article class="why-card card">
            <div class="why-icon">✦</div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section qp-testimonials-band">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Testimonials</span>
        <h2 class="section-title">{copy.testimonialsTitle}</h2>
      </div>
      <div class="testimonial-grid">
        {copy.testimonials.map(testimonial => (
          <article class="testimonial-card card">
            <p class="testimonial-quote">“{testimonial.quote}”</p>
            <div class="testimonial-meta">
              <strong>{testimonial.name}</strong>
              <span>{testimonial.meta}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section qp-faq-band">
    <div class="container qp-faq-wrap">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">FAQ</span>
        <h2 class="section-title">{copy.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {copy.faqs.map((faq, idx) => (
          <details class="faq-item card" open={idx === 0}>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section qp-final-band">
    <div class="container qp-final-grid">
      <div class="qp-section-copy">
        <span class="badge badge-primary">{copy.finalBadge}</span>
        <h2 class="section-title">{copy.finalTitle}</h2>
        <p class="section-body">{copy.finalBody1}</p>
        <p class="section-body">{copy.finalBody2}</p>
        <div class="qp-cta-row">
          <a href="https://apps.apple.com/us/search?term=Quran%20Pak" class="store-btn dark" target="_blank" rel="noopener noreferrer">
            <img src={storeBadge} alt={copy.finalAppStore} class="store-badge" />
            <span>{copy.finalAppStore}</span>
          </a>
          <a href="#features" class="btn btn-secondary">{copy.finalLearn}</a>
        </div>
      </div>
      <aside class="final-panel card">
        <img src="/images/QP.webp" alt="Quran Pak logo" class="final-logo" />
        <p>{copy.footerDesc}</p>
      </aside>
    </div>
  </section>

  <section class="section qp-footer-summary">
    <div class="container">
      <p>{copy.footerDesc}</p>
    </div>
  </section>
</Layout>

<style>
  .qp-hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 4.5rem);
    display: flex;
    align-items: center;
    padding: 2.5rem 0 2rem;
    background:
      linear-gradient(135deg, rgba(255,251,246,.98), rgba(255,245,235,.94)),
      url('/images/quranmajeed/bg-18-Copy-Copy.jpg') center/cover no-repeat;
  }

  .qp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(115deg, rgba(255,255,255,.74), transparent 46%),
      linear-gradient(0deg, rgba(255,255,255,.12), rgba(255,255,255,.12));
    pointer-events: none;
  }

  .qp-hero-grid,
  .qp-split,
  .qp-media-grid,
  .qp-final-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .qp-hero-grid {
    position: relative;
    z-index: 1;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, .92fr);
    gap: 1.5rem;
  }

  .qp-copy,
  .qp-section-copy {
    max-width: 46rem;
  }

  .qp-badge,
  .badge {
    margin-bottom: 1rem;
  }

  .qp-badge {
    box-shadow: 0 8px 24px rgba(249,115,22,.08);
  }

  .qp-title {
    font-size: clamp(1.8rem, 2.5vw, 3rem);
    line-height: 1.05;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--primary);
  }

  .qp-lead {
    font-size: clamp(.98rem, 1.15vw, 1.08rem);
    line-height: 1.55;
    margin-bottom: 1rem;
    color: var(--dark);
    max-width: 38rem;
  }

  .qp-body,
  .section-body,
  .testimonial-quote,
  .faq-item p {
    color: var(--secondary-dark);
    line-height: 1.55;
    font-size: .96rem;
    max-width: 38rem;
  }

  .qp-trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-top: .95rem;
  }

  .qp-trust-item {
    padding: .42rem .72rem;
    border-radius: 999px;
    border: 1px solid rgba(249,115,22,.14);
    background: rgba(255,255,255,.8);
    color: var(--dark);
    font-size: .84rem;
    font-weight: 700;
    box-shadow: 0 8px 20px rgba(15,23,42,.05);
  }

  .qp-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin-top: 1.1rem;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    padding: .8rem 1rem;
    border-radius: .5rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,.94);
    color: var(--dark);
    font-weight: 600;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .store-btn:hover,
  .store-btn:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(15,23,42,.08);
    border-color: rgba(249,115,22,.35);
  }

  .store-btn.dark {
    background: rgba(255,255,255,.12);
    color: #fff;
    border-color: rgba(255,255,255,.18);
  }

  .store-badge {
    width: 1.35rem;
    height: 1.35rem;
    object-fit: contain;
  }

  .qp-explore {
    align-self: center;
  }

  .highlight-bar {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-top: .9rem;
  }

  .highlight-pill,
  .proof-chip,
  .mini-card {
    border-radius: .5rem;
    border: 1px solid rgba(249,115,22,.12);
    background: rgba(255,255,255,.94);
    padding: .5rem .75rem;
    font-size: .92rem;
    font-weight: 600;
    box-shadow: 0 8px 18px rgba(15,23,42,.05);
  }

  .qp-showcase {
    position: relative;
  }

  .qp-showcase-shell {
    position: sticky;
    top: 5.6rem;
    padding: 1rem;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255,255,255,.97), rgba(255,250,245,.94));
    border: 1px solid rgba(249,115,22,.12);
    box-shadow: 0 24px 50px rgba(15,23,42,.1);
  }

  .qp-showcase-top {
    display: flex;
    justify-content: space-between;
    gap: .9rem;
    align-items: center;
    margin-bottom: .85rem;
  }

  .qp-showcase-brand {
    display: flex;
    align-items: center;
    gap: .9rem;
  }

  .qp-brand-logo {
    width: 3.6rem;
    height: 3.6rem;
    object-fit: contain;
    border-radius: 1rem;
    box-shadow: 0 12px 28px rgba(15,23,42,.08);
  }

  .qp-download-card-label {
    font-size: .8rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--secondary-dark);
    margin-bottom: .2rem;
  }

  .qp-download-card-title {
    font-size: 1.5rem;
    line-height: 1;
    margin: 0;
    font-weight: 800;
  }

  .qp-showcase-badge {
    align-self: flex-start;
    padding: .45rem .75rem;
    border-radius: 999px;
    background: rgba(249,115,22,.11);
    color: var(--primary);
    font-size: .82rem;
    font-weight: 700;
  }

  .qp-showcase-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(160px, .82fr);
    gap: .7rem;
    margin: .85rem 0;
  }

  .qp-shot-main,
  .qp-shot-stack img {
    width: 100%;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid rgba(249,115,22,.12);
    background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(255,247,238,.94));
    box-shadow: 0 14px 30px rgba(15,23,42,.08);
  }

  .qp-shot-main {
    height: 17rem;
    object-fit: contain;
    padding: .7rem;
  }

  .qp-shot-stack {
    display: grid;
    gap: .65rem;
  }

  .qp-shot-stack img {
    aspect-ratio: 1 / 1.12;
    height: 8rem;
    object-fit: cover;
  }

  .qp-download-card-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .65rem;
    margin-bottom: 1rem;
  }

  .qp-download-stat {
    border-radius: .75rem;
    background: rgba(255,255,255,.92);
    border: 1px solid rgba(249,115,22,.12);
    padding: .85rem;
    font-size: .875rem;
    line-height: 1.4;
  }

  .proof-chip {
    background: rgba(249,115,22,.08);
    border-color: rgba(249,115,22,.15);
  }

  .qp-section-intro,
  .qp-section-features,
  .qp-testimonials-band {
    padding-top: 1.5rem;
  }

  .qp-split {
    grid-template-columns: minmax(0, 1fr) minmax(320px, 1fr);
  }

  .section-title {
    font-size: clamp(1.8rem, 2.6vw, 3rem);
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .stat-grid,
  .feature-grid,
  .testimonial-grid,
  .why-grid {
    display: grid;
    gap: 1rem;
  }

  .stat-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-card,
  .feature-card,
  .testimonial-card,
  .why-card {
    padding: 1rem;
    border-radius: .5rem;
    background: rgba(255,255,255,.96);
    border: 1px solid var(--border);
    box-shadow: 0 10px 24px rgba(15,23,42,.05);
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: .75rem;
  }

  .stat-dot {
    width: .7rem;
    height: .7rem;
    border-radius: 999px;
    background: var(--primary);
    flex: none;
  }

  .feature-grid,
  .testimonial-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card h3,
  .why-card h3 {
    margin: .75rem 0 .5rem;
    font-size: 1.1rem;
  }

  .feature-index {
    width: 2rem;
    height: 2rem;
    display: inline-grid;
    place-items: center;
    border-radius: .5rem;
    background: rgba(249,115,22,.12);
    color: var(--primary);
    font-weight: 700;
  }

  .qp-reading-band,
  .qp-learn-band,
  .qp-final-band {
    background: rgba(255,250,244,.7);
  }

  .qp-media-grid {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }

  .screenshot-carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(160px, 1fr);
    gap: .85rem;
    overflow-x: auto;
    padding-bottom: .25rem;
    scroll-snap-type: x proximity;
  }

  .screenshot-carousel img {
    aspect-ratio: 9 / 16;
    scroll-snap-align: start;
  }

  .mini-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .75rem;
    margin-top: 1.2rem;
  }

  .why-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .why-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: .5rem;
    display: inline-grid;
    place-items: center;
    background: rgba(249,115,22,.1);
    color: var(--primary);
    font-size: 1rem;
    margin-bottom: .6rem;
  }

  .testimonial-quote {
    font-size: 1.02rem;
    margin-bottom: .9rem;
  }

  .testimonial-meta {
    display: flex;
    flex-direction: column;
    gap: .15rem;
  }

  .faq-list {
    display: grid;
    gap: .8rem;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 1rem 1.1rem;
    font-weight: 700;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    padding: 0 1.1rem 1rem;
    margin: 0;
  }

  .qp-final-grid {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.75fr);
  }

  .final-panel {
    padding: 1.25rem;
    border-radius: .5rem;
    background: linear-gradient(180deg, rgba(15,23,42,.95), rgba(30,41,59,.92));
    color: #fff;
  }

  .final-panel p {
    margin-top: .9rem;
    color: rgba(255,255,255,.9);
    line-height: 1.75;
  }

  .qp-footer-summary p {
    color: var(--secondary-dark);
    line-height: 1.75;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .qp-hero-grid,
    .qp-split,
    .qp-media-grid,
    .qp-final-grid {
      grid-template-columns: 1fr;
    }

    .qp-showcase-shell {
      order: -1;
      position: static;
    }
  }

  @media (max-width: 720px) {
    .qp-hero {
      min-height: auto;
      padding: 2rem 0 1.5rem;
    }

    .feature-grid,
    .testimonial-grid,
    .why-grid,
    .stat-grid,
    .mini-grid {
      grid-template-columns: 1fr;
    }

    .qp-showcase-hero {
      grid-template-columns: 1fr;
    }

    .highlight-bar,
    .qp-cta-row {
      gap: .55rem;
    }

    .qp-showcase-shell {
      padding: 1rem;
    }

    .qp-showcase-top {
      align-items: flex-start;
      flex-direction: column;
    }

    .qp-shot-main {
      height: 16rem;
    }

    .qp-shot-stack {
      grid-template-columns: 1fr 1fr;
    }
  }

  :global(html[dir='rtl']) .qp-hero-grid,
  :global(html[dir='rtl']) .qp-split,
  :global(html[dir='rtl']) .qp-media-grid,
  :global(html[dir='rtl']) .qp-final-grid {
    direction: rtl;
  }

  :global(html[dir='rtl']) .qp-copy,
  :global(html[dir='rtl']) .qp-section-copy,
  :global(html[dir='rtl']) .section-title-wrap,
  :global(html[dir='rtl']) .testimonial-meta,
  :global(html[dir='rtl']) .final-panel {
    text-align: start;
  }
</style>
