      { q: 'هل يدعم كتبي الكتب الصوتية؟', a: 'نعم. يتضمن كتبي دعمًا للكتب الصوتية مع عناصر تحكم سلسة للتشغيل والاستماع بسهولة.' },
      { q: 'هل يمكنني تخصيص الخطوط والسمات؟', a: 'نعم. يمكنك ضبط الخطوط وحجم النص والسطوع والسمات والتخطيطات لتجربة قراءة مريحة.' },
      { q: 'هل التطبيق مجاني؟', a: 'صُمم كتبي لتقديم تجربة قراءة أردية حديثة، مع اختلاف التوفر والوصول حسب المنصة والمنطقة.' }
    ],
    finalTitle: 'ابدأ رحلتك مع القراءة الأردية اليوم',
    finalBody1: 'حمّل كتبي واكتشف عالمًا حديثًا من الكتب الأردية والكتب الصوتية وتجارب القراءة الرقمية الغامرة.',
    finalBody2: 'من الخيال والشعر إلى الأدب الإسلامي والقراءة التعليمية، يضع كتبي المحتوى الأردي داخل تجربة هاتفية أنيقة.',
    footerDesc: 'كتابي منصة قراءة رقمية أردية حديثة تقدم الكتب والكتب الصوتية وتجارب قراءة قابلة للتخصيص ومكتبة متنامية للقراء حول العالم.'
  }
}[lang];

const featureImages = [
  '/images/kitabi/unnamed.webp',
  '/images/kitabi/unnamed (1).webp',
  '/images/kitabi/unnamed (2).webp',
  '/images/kitabi/unnamed (3).webp'
];

const storeLinks = [
  { href: 'https://apps.apple.com/us/search?term=Kitabi', label: copy.appStore },
  { href: 'https://play.google.com/store/search?q=Kitabi&c=apps', label: copy.googlePlay }
];
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="kitabi-hero">
    <div class="container kitabi-grid">
      <div class="kitabi-copy">
        <span class="badge badge-primary kitabi-eyebrow">{copy.heroBadge}</span>
        <h1 class="kitabi-title">{copy.heroTitle}</h1>
        <p class="kitabi-lead">{copy.heroLead}</p>
        <p class="kitabi-body">{copy.heroBody}</p>

        <div class="kitabi-trust-strip" aria-label="Kitabi highlights">
          {copy.trustStats.map(item => <span class="kitabi-trust-item">{item}</span>)}
        </div>

        <div class="kitabi-cta-row">
          {storeLinks.map(link => (
            <a href={link.href} class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
          <a href="#features" class="btn btn-outline btn-lg kitabi-explore">{copy.explore}</a>
        </div>
      </div>

      <aside class="kitabi-showcase">
        <div class="kitabi-showcase-shell card">
          <div class="kitabi-showcase-top">
            <div class="kitabi-brand">
              <img src="/images/kitabi/kitabi.webp" alt="Kitabi logo" class="kitabi-logo" />
              <div>
                <p class="kitabi-caption">{copy.trustTitle}</p>
                <h2 class="kitabi-rating">4.9★</h2>
              </div>
            </div>
            <div class="kitabi-badge">Urdu books</div>
          </div>

          <div class="kitabi-showcase-main">
            <img src={featureImages[3]} alt="Kitabi reading screen" class="kitabi-main-shot" />
            <div class="kitabi-side-stack">
              <img src={featureImages[0]} alt="Kitabi library screen" />
              <img src={featureImages[2]} alt="Kitabi reading screen" />
            </div>
          </div>

          <div class="kitabi-stats-grid">
            <div class="kitabi-stat">Urdu books</div>
            <div class="kitabi-stat">Audiobooks</div>
            <div class="kitabi-stat">Offline reading</div>
            <div class="kitabi-stat">Smart search</div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">Introduction</span>
        <h2 class="section-title">{copy.introTitle}</h2>
        <p class="body-copy">{copy.introBody1}</p>
        <p class="body-copy">{copy.introBody2}</p>
      </div>
      <div class="info-panel card">
        <img src="/images/kitabi/kitabi.webp" alt="Kitabi icon" class="info-icon" />
        <div class="info-list">
          <div>Urdu novels</div>
          <div>Poetry collections</div>
          <div>Islamic literature</div>
          <div>Digital audiobooks</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Library</span>
        <h2 class="section-title">{copy.libraryTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.libraryBody}</p>
      <div class="chip-grid">
        {copy.categories.map(category => <div class="chip">{category}</div>)}
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Features</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>
      <div class="feature-grid">
        {copy.features.map((feature, index) => (
          <article class="feature-card card">
            <div class="feature-index">0{index + 1}</div>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-grid reverse">
      <div class="split-copy">
        <span class="badge badge-primary">Audiobooks</span>
        <h2 class="section-title">{copy.audiobookTitle}</h2>
        <p class="body-copy">{copy.audiobookBody}</p>
        <div class="mini-grid">
          <div class="mini-pill">Playback controls</div>
          <div class="mini-pill">Easy listening</div>
          <div class="mini-pill">Travel friendly</div>
          <div class="mini-pill">Background audio</div>
        </div>
      </div>
      <div class="shot-grid">
        <img src={featureImages[1]} alt="Kitabi audiobook screen" class="shot-card large" />
        <img src={featureImages[2]} alt="Kitabi reading screen" class="shot-card" />
        <img src={featureImages[0]} alt="Kitabi book library screen" class="shot-card" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">Customization</span>
        <h2 class="section-title">{copy.customizeTitle}</h2>
        <p class="body-copy">{copy.customizeBody}</p>
      </div>
      <div class="custom-panel card">
        <img src={featureImages[3]} alt="Kitabi reading preview" />
        <div class="custom-bars">
          <span>Classic theme</span>
          <span>Serif font</span>
          <span>Large text</span>
          <span>Night mode</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Why Kitabi</span>
        <h2 class="section-title">{copy.whyTitle}</h2>
      </div>
      <div class="why-grid">
        {copy.whyItems.map(item => (
          <article class="why-card card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid reverse">
      <div class="shot-grid secondary">
        <img src={featureImages[0]} alt="Kitabi library" class="shot-card tall" />
        <img src={featureImages[1]} alt="Kitabi audiobook" class="shot-card" />
      </div>
      <div class="split-copy">
        <span class="badge badge-primary">Community</span>
        <h2 class="section-title">{copy.communityTitle}</h2>
        <p class="body-copy">{copy.communityBody}</p>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Reviews</span>
        <h2 class="section-title">{copy.reviewsTitle}</h2>
      </div>
      <div class="review-grid">
        {copy.reviews.map(review => (
          <article class="review-card card">
            <p class="review-quote">“{review.quote}”</p>
            <div class="review-meta">
              <strong>{review.name}</strong>
              <span>{review.meta}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container faq-wrap">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">FAQ</span>
        <h2 class="section-title">{copy.faqTitle}</h2>
      </div>
      <div class="faq-list">
        {copy.faqs.map((faq, idx) => (
          <details class="faq-item card" open={idx === 0}>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta-band">
    <div class="container final-cta-grid">
      <div>
        <span class="badge badge-primary">Start Now</span>
        <h2 class="section-title">{copy.finalTitle}</h2>
        <p class="body-copy">{copy.finalBody1}</p>
        <p class="body-copy">{copy.finalBody2}</p>
        <div class="kitabi-cta-row">
          {storeLinks.map(link => (
            <a href={link.href} class="btn btn-primary btn-lg" target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
      <div class="final-art card">
        <img src="/images/kitabi/kitabi.webp" alt="Kitabi logo" class="final-logo" />
        <p>{copy.footerDesc}</p>
      </div>
    </div>
  </section>

  <section class="section footer-summary">
    <div class="container">
      <p>{copy.footerDesc}</p>
    </div>
  </section>
</Layout>

<style>
  .kitabi-hero {
    min-height: calc(100vh - 4.5rem);
    display: flex;
    align-items: center;
    padding: 2.5rem 0 2rem;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(255,252,246,.98), rgba(250,240,223,.94)),
      url('/images/kitabi/kitabi.webp') center/240px no-repeat;
  }

  .kitabi-grid,
  .split-grid,
  .final-cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr);
    gap: 2rem;
    align-items: center;
  }

  .kitabi-copy {
    text-align: start;
  }

  .kitabi-eyebrow,
  .section-title-wrap .badge {
    margin-bottom: 1rem;
  }

  .kitabi-title {
    font-size: 3rem;
    line-height: 1.02;
    color: var(--primary-dark);
    max-width: 12ch;
    margin-bottom: 1.25rem;
    letter-spacing: 0;
  }

  .kitabi-lead {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--secondary-dark);
    max-width: 44rem;
    margin-bottom: 1rem;
  }

  .kitabi-body,
  .body-copy,
  .section-copy {
    color: var(--secondary-dark);
    line-height: 1.7;
    font-size: 1rem;
  }

  .kitabi-trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin: 1.5rem 0 1.75rem;
  }

  .kitabi-trust-item,
  .chip,
  .mini-pill,
  .kitabi-stat {
    border: 1px solid rgba(251, 146, 60, .22);
    background: rgba(255,255,255,.85);
    color: var(--dark);
    border-radius: .75rem;
    padding: .7rem .95rem;
    font-weight: 600;
    box-shadow: var(--shadow-sm);
  }

  .kitabi-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    margin-top: 1rem;
  }

  .kitabi-explore {
    background: rgba(255,255,255,.8);
  }

  .kitabi-showcase-shell,
  .info-panel,
  .custom-panel,
  .final-art {
    border-radius: 1.25rem;
    padding: 1.25rem;
    background: rgba(255,255,255,.9);
    border: 1px solid rgba(251, 146, 60, .14);
    box-shadow: var(--shadow-lg);
  }

  .kitabi-showcase-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .kitabi-brand {
    display: flex;
    gap: .85rem;
    align-items: center;
  }

  .kitabi-logo,
  .info-icon,
  .final-logo {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: .9rem;
    object-fit: cover;
    box-shadow: var(--shadow-sm);
  }

  .kitabi-caption {
    font-size: .82rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--secondary-dark);
    margin-bottom: .2rem;
  }

  .kitabi-rating {
    font-size: 1.55rem;
    line-height: 1;
    color: var(--dark);
  }

  .kitabi-badge {
    padding: .8rem 1rem;
    border-radius: 999px;
    background: rgba(255, 237, 213, .95);
    color: var(--primary);
    font-weight: 700;
    font-size: .95rem;
  }

  .kitabi-showcase-main {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, .9fr);
    gap: .9rem;
    align-items: stretch;
  }

  .kitabi-main-shot,
  .kitabi-side-stack img,
  .shot-card,
  .custom-panel img,
  .info-panel img {
    width: 100%;
    display: block;
    border-radius: 1rem;
    object-fit: cover;
    box-shadow: var(--shadow-sm);
    background: #fff;
  }

  .kitabi-side-stack {
    display: grid;
    gap: .9rem;
  }

  .kitabi-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .75rem;
    margin-top: 1rem;
  }

  .section {
    padding: 4.5rem 0;
  }

  .section-bg {
    background: linear-gradient(180deg, rgba(255,248,240,.72), rgba(255,255,255,.94));
  }

  .section-title-wrap.tight {
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2.25rem;
    line-height: 1.12;
    color: var(--primary-dark);
    margin-bottom: .75rem;
  }

  .section-copy {
    max-width: 60rem;
    margin-bottom: 1.5rem;
  }

  .chip-grid,
  .mini-grid,
  .why-grid,
  .review-grid {
    display: grid;
    gap: 1rem;
  }

  .chip-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-grid,
  .why-grid,
  .review-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-card,
  .why-card,
  .review-card,
  .faq-item,
  .info-panel,
  .custom-panel {
    background: rgba(255,255,255,.94);
    border: 1px solid rgba(251, 146, 60, .14);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
  }

  .feature-index {
    display: inline-flex;
    margin-bottom: .9rem;
    color: var(--primary);
    font-weight: 800;
  }

  .feature-card h3,
  .why-card h3 {
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--dark);
    margin-bottom: .6rem;
  }

  .feature-card p,
  .why-card p,
  .review-card p,
  .faq-item p,
  .info-list div,
  .custom-bars span {
    color: var(--secondary-dark);
    line-height: 1.65;
  }

  .split-grid.reverse {
    direction: ltr;
  }

  .split-copy {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .info-panel {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
  }

  .info-list {
    display: grid;
    gap: .75rem;
    font-weight: 600;
  }

  .shot-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .9rem;
  }

  .shot-grid.secondary {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .shot-card.large,
  .shot-card.tall {
    grid-column: 1 / -1;
  }

  .mini-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .custom-panel {
    display: grid;
    gap: 1rem;
  }

  .custom-bars {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .final-cta-band {
    background: linear-gradient(135deg, rgba(255,243,232,.98), rgba(255,252,247,.96));
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--dark);
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    margin-top: .75rem;
  }

  .footer-summary {
    padding-top: 0;
  }

  .footer-summary p {
    color: var(--secondary-dark);
    text-align: center;
    max-width: 65rem;
    margin: 0 auto;
    line-height: 1.8;
  }

  @media (max-width: 1100px) {
    .kitabi-grid,
    .split-grid,
    .final-cta-grid {
      grid-template-columns: 1fr;
    }

    .kitabi-title {
      max-width: 100%;
    }

    .kitabi-showcase-main {
      grid-template-columns: 1fr;
    }

    .kitabi-stats-grid,
    .chip-grid,
    .feature-grid,
    .why-grid,
    .review-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .kitabi-hero {
      min-height: auto;
      padding: 2rem 0 1rem;
    }

    .kitabi-title {
      font-size: 2.35rem;
    }

    .section-title {
      font-size: 1.8rem;
    }

    .kitabi-stats-grid,
    .chip-grid,
    .feature-grid,
    .why-grid,
    .review-grid,
    .shot-grid,
    .mini-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
