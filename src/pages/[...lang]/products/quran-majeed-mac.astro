    whyBody: 'جو صارفین ڈیسک ٹاپ پر قرآن پڑھنا پسند کرتے ہیں، ان کے لیے قرآن مجید برائے میک موبائل تجربے کا وہی اعتماد، احترام اور وضاحت بڑی ورک سٹیشن اسکرین پر لاتا ہے۔',
    whyItems: [
      'میک پر خوبصورت قرآن ڈسپلے',
      'مستند مطالعہ تجربہ',
      'آڈیو اور ترجمہ سپورٹ',
      'لمبے مطالعے کے لیے موزوں',
      'ایپل میکنٹوش صارفین کے لیے تیار'
    ],
    finalTitle: 'میک پر قرآنِ مجید آرام سے پڑھیں',
    finalBody: 'ایپل میکنٹوش کے لیے بنایا گیا ایک مستند اور خوبصورت قرآن ایپ تجربہ حاصل کریں جس میں درست رسم الخط، تلاوتیں اور تراجم شامل ہیں۔',
    contact: 'ہم سے رابطہ کریں',
    explore: 'خصوصیات دیکھیں',
    footerDesc: 'قرآن مجید برائے میک ایپل میکنٹوش پر مستند قرآنی مطالعہ، عثمانی رسم الخط، مکمل سورہ البقرہ، آڈیو تلاوتیں اور تراجم فراہم کرتا ہے۔'
  },
  ar: {
    seoTitle: 'القرآن المجيد للماك - تطبيق قرآن أصيل لأجهزة Apple Macintosh',
    seoDesc: 'يوفر القرآن المجيد للماك قراءة قرآنية أصيلة بخط عثماني، وسورة البقرة كاملة، وتلاوات صوتية وترجمات على Apple Macintosh.',
    badge: 'القرآن المجيد للماك',
    title: 'القرآن المجيد للماك',
    lead: 'القرآن المجيد هو تطبيق قرآن رائع يجمّل حياتك بنعمة قراءة القرآن والاستماع إليه على جهاز الماك.',
    body: 'يوفر أحدث إصدار من تطبيق القرآن المجيد الأصيل لأجهزة Apple Macintosh سورة البقرة كاملة بالخط العثماني الأنيق، تمت مراجعته من قبل عالم مسلم، مع تلاوات صوتية متعددة وترجمات لتجربة قرآنية مكتبية راقية.',
    primaryCta: 'اتصل بنا',
    secondaryCta: 'استكشف الميزات',
    trust: ['Apple Macintosh', 'الخط العثماني', 'تلاوات صوتية', 'ترجمات', 'مراجعة عالم'],
    overviewTitle: 'قراءة قرآنية أصيلة على الماك',
    overviewBody: 'تم تصميم هذا الإصدار المكتبي للمستخدمين الذين يرغبون في تجربة قراءة قرآنية هادئة وراقية على Apple Macintosh. يجمع بين عرض النص العربي الدقيق ودعم التلاوات والترجمات حتى يمكن قراءة القرآن والاستماع إليه براحة على شاشة كبيرة.',
    featuresTitle: 'ميزات مصممة لمستخدمي الماك',
    features: [
      { title: 'سورة البقرة كاملة', body: 'اقرأ عرضًا كاملًا لسورة البقرة بالخط العثماني الأنيق مع مراجعة دقيقة.' },
      { title: 'تلاوات صوتية متعددة', body: 'استمع إلى عدة تلاوات للقرآن أثناء التنقل في النص بوتيرة مريحة على سطح المكتب.' },
      { title: 'ترجمات', body: 'ادرس المعنى عبر دعم الترجمة المصمم لتسهيل القراءة والتأمل.' },
      { title: 'قراءة مناسبة للماك', body: 'استمتع بتخطيط قراءة مكتبي ثابت وطبيعي على شاشات Apple Macintosh.' }
    ],
    scriptTitle: 'خط عثماني مع مراجعة دقيقة',
    scriptBody: 'تم تصميم الخط والتخطيط ليبقيا قريبين من تقاليد المصحف مع وضوح عالٍ على شاشات الماك الحديثة. وقد تمت مراجعته من قبل عالم مسلم ليقرأ المستخدم بثقة ووضوح.',
    visualTitle: 'عرض التطبيق المكتبي',
    visualBody: 'تسلط واجهة العرض الضوء على بيئة الماك وشاشة القراءة في القرآن المجيد ليبدو التطبيق طبيعيًا لمستخدمي Apple.',
    whyTitle: 'لماذا هذا الإصدار مهم',
    whyBody: 'للمستخدمين الذين يفضلون القراءة على سطح المكتب، ينقل القرآن المجيد للماك نفس الثقة والوقار والوضوح من تجربة الهاتف إلى تنسيق مناسب للعمل على شاشة أكبر.',
    whyItems: [
      'عرض قرآني جميل على الماك',
      'تجربة قراءة أصيلة',
      'دعم التلاوة والترجمة',
      'مناسب لجلسات القراءة الطويلة',
      'مصمم لمستخدمي Apple Macintosh'
    ],
    finalTitle: 'اقرأ القرآن براحة على الماك',
    finalBody: 'استمتع بتجربة تطبيق قرآن أصيل وأنيق مصمم لـ Apple Macintosh مع الخط والتلاوات والترجمات التي تحتاجها للقراءة المركّزة.',
    contact: 'اتصل بنا',
    explore: 'استكشف الميزات',
    footerDesc: 'يوفر القرآن المجيد للماك قراءة قرآنية أصيلة بخط عثماني، وسورة البقرة كاملة، وتلاوات صوتية وترجمات على Apple Macintosh.'
  }
}[lang];
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="mac-hero">
    <div class="container mac-grid">
      <div class="mac-copy">
        <span class="badge badge-primary">{copy.badge}</span>
        <h1 class="mac-title">{copy.title}</h1>
        <p class="mac-lead">{copy.lead}</p>
        <p class="mac-body">{copy.body}</p>

        <div class="mac-trust">
          {copy.trust.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>

        <div class="mac-actions">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.primaryCta}</a>
          <a href="#mac-features" class="btn btn-outline btn-lg">{copy.secondaryCta}</a>
        </div>
      </div>

      <div class="mac-visual card">
        <div class="mac-frame">
          <img src="/images/qm-mac.png" alt="Apple Macintosh product visual" class="mac-device" />
          <img src="/images/Mac.png" alt="Quran Majeed Mac app screenshot" class="mac-screen" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-grid card">
        <div class="info-row">
          <span class="info-kicker">Platform</span>
          <strong>Apple Macintosh</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Script</span>
          <strong>Uthmanic Arabic</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Content</span>
          <strong>Surah Al-Baqarah, recitations, translations</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg" id="mac-features">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.featuresTitle}</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>

      <div class="feature-grid">
        {copy.features.map((feature) => (
          <article class="feature-card card">
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.scriptTitle}</span>
        <h2 class="section-title">{copy.scriptTitle}</h2>
        <p class="body-copy">{copy.scriptBody}</p>
      </div>
      <div class="visual-stack">
        <img src="/images/qm-mac.png" alt="Quran Majeed Mac screenshot" class="stack-shot" />
        <img src="/images/Mac.png" alt="Mac product illustration" class="stack-frame" />
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.whyTitle}</span>
        <h2 class="section-title">{copy.whyTitle}</h2>
        <p class="body-copy">{copy.whyBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Why it stands out</h3>
        <ul class="check-list">
          {copy.whyItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section mac-cta">
    <div class="container text-center text-white">
      <h2 class="cta-title">{copy.finalTitle}</h2>
      <p class="cta-desc">{copy.finalBody}</p>
      <div class="cta-actions">
        <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg btn-white-text">{copy.primaryCta}</a>
        <a href="#mac-features" class="btn btn-outline btn-lg btn-white-text">{copy.secondaryCta}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .mac-hero {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, #fefbf8, #fff);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 4rem;
  }

  .mac-grid,
  .split-layout {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 2rem;
    align-items: center;
  }

  .split-layout.reverse {
    grid-template-columns: .95fr 1.05fr;
  }

  .mac-title {
    font-size: clamp(1.8rem, 2.5vw, 3rem);
    line-height: 1.05;
    font-weight: 700;
    color: var(--primary);
    margin: .9rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .mac-lead,
  .mac-body,
  .body-copy {
    color: var(--secondary-dark);
    line-height: 1.7;
    font-size: calc(1.02rem * var(--text-scale, 1));
  }

  .mac-body {
    margin-top: .9rem;
  }

  .mac-trust {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin: 1.3rem 0 1.4rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: .45rem .85rem;
    border-radius: 999px;
    background: var(--primary-light);
    color: var(--dark);
    font-weight: 700;
    font-size: .86rem;
  }

  .mac-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    margin-top: 1.3rem;
  }

  .mac-visual,
  .info-grid,
  .list-panel {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1.2rem;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .mac-visual {
    padding: 1rem;
  }

  .mac-frame {
    position: relative;
    min-height: 28rem;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, rgba(255,255,255,.8), rgba(255,255,255,.96));
    border-radius: 1rem;
    overflow: hidden;
  }

  .mac-device {
    display: block;
    width: min(100%, 34rem);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 25px 40px rgba(15,23,42,.12));
  }

  .mac-screen {
    position: absolute;
    width: min(46%, 18rem);
    height: auto;
    object-fit: contain;
    right: 8%;
    bottom: 8%;
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(15,23,42,.16);
    border: 1px solid rgba(15,23,42,.08);
    background: #fff;
  }

  .section-title {
    font-size: clamp(1.65rem, 2.8vw, 2.65rem);
    line-height: 1.12;
    margin: .7rem 0 .9rem;
    color: var(--dark);
  }

  .section-copy-block {
    max-width: 42rem;
  }

  .section-title-wrap.tight {
    margin-bottom: 1.3rem;
  }

  .info-grid,
  .list-panel {
    padding: 1.3rem;
  }

  .info-row {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .info-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .info-kicker {
    display: block;
    font-size: .76rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--primary);
    margin-bottom: .35rem;
  }

  .info-row strong {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--dark);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .feature-card {
    padding: 1.25rem;
  }

  .feature-card h3,
  .panel-title {
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--dark);
    margin-bottom: .65rem;
  }

  .feature-card p {
    color: var(--secondary-dark);
    line-height: 1.6;
  }

  .visual-stack {
    position: relative;
    min-height: 28rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1.2rem;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .stack-shot {
    position: absolute;
    width: 68%;
    left: 8%;
    top: 10%;
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(15,23,42,.16);
    border: 1px solid rgba(15,23,42,.08);
    background: #fff;
  }

  .stack-frame {
    position: absolute;
    width: 52%;
    right: 6%;
    bottom: 8%;
