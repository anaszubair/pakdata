---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}

import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, getRelativeLocaleUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const copy = {
  en: {
    seoTitle: 'Quran Majeed for Mac - Authentic Quran App for Apple Macintosh',
    seoDesc: 'Quran Majeed for Mac offers authentic Quran reading with Uthmanic script, complete Surah Al-Baqarah, audio recitations, and translations on Apple Macintosh.',
    badge: 'Quran Majeed Mac',
    title: 'Quran Majeed for Mac',
    lead: 'Quran Majeed is an amazing Quran app that beautifies your life with the blessing of reading and listening to the Quran on your Mac.',
    body: 'The latest version of the authentic Quran Majeed app for Apple Macintosh offers complete Surah Al-Baqarah in the elegant Uthmanic script proofread by a Muslim scholar, multiple audio recitations, and translations for a graceful desktop Quran experience.',
    primaryCta: 'Contact Us',
    secondaryCta: 'Explore Features',
    trust: ['Apple Macintosh', 'Uthmanic script', 'Audio recitations', 'Translations', 'Scholar proofread'],
    overviewTitle: 'Authentic Quran Reading on Mac',
    overviewBody: 'This desktop edition is designed for users who want a calm and refined Quran reading experience on Apple Macintosh. It combines accurate Arabic text rendering with recitations and translation support so the Quran can be read and listened to comfortably on a larger screen.',
    featuresTitle: 'Features Designed for Mac Users',
    features: [
      { title: 'Complete Surah Al-Baqarah', body: 'Read a complete Surah Al-Baqarah presentation in elegant Uthmanic script with careful proofreading.' },
      { title: 'Multiple Audio Recitations', body: 'Listen to multiple Quran recitations while moving through the text at a comfortable desktop pace.' },
      { title: 'Translations', body: 'Study the meaning with translation support designed to make reading and reflection easier.' },
      { title: 'Mac-Friendly Reading', body: 'Enjoy a stable desktop reading layout that feels natural on Apple Macintosh screens.' }
    ],
    scriptTitle: 'Uthmanic Script With Careful Review',
    scriptBody: 'The font and layout are designed to stay close to Quranic tradition while remaining highly legible on modern Mac displays. It is proofread by a Muslim scholar so users can read with confidence and clarity.',
    visualTitle: 'Desktop App Showcase',
    visualBody: 'The product presentation highlights the Mac environment and the Quran Majeed reading screen so the app feels native to Apple users.',
    whyTitle: 'Why This Version Matters',
    whyBody: 'For users who prefer reading on a desktop, Quran Majeed for Mac brings the same trust, reverence, and clarity of the mobile experience into a larger workstation-friendly format.',
    whyItems: [
      'Beautiful Quran display on Mac',
      'Authentic reading experience',
      'Audio and translation support',
      'Ideal for long reading sessions',
      'Designed for Apple Macintosh users'
    ],
    finalTitle: 'Read the Quran Comfortably on Mac',
    finalBody: 'Experience an authentic and elegant Quran app made for Apple Macintosh with the script, recitations, and translations you need for focused reading.',
