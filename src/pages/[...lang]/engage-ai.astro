---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="engage-hero">
    <div class="container engage-hero-grid">
      <div class="engage-copy">
        <span class="badge badge-primary">{copy.badge}</span>
        <h1 class="engage-title">{copy.heroTitle}</h1>
        <p class="engage-lead">{copy.heroLead}</p>
        <p class="engage-body">{copy.heroBody}</p>
        <p class="engage-body">{copy.heroBody2}</p>
        <div class="engage-cta-row">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.primaryCta}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.secondaryCta}</a>
        </div>
      </div>
      <div class="engage-shell">
        <div class="engage-panel card">
          <div class="engage-panel-head">
            <span class="panel-pill">{copy.badge}</span>
            <strong>99.9%</strong>
          </div>
          <div class="engage-dashboard">
            <div class="dash-card">24/7 AI support</div>
            <div class="dash-card">Lead qualification</div>
            <div class="dash-card">Multilingual chat</div>
            <div class="dash-card">Analytics insights</div>
          </div>
          <div class="engage-flow">
            <div class="flow-node">Website</div>
            <div class="flow-node">EngageAI</div>
            <div class="flow-node">CRM / Helpdesk</div>
          </div>
        </div>
      </div>
    </div>
    <div class="container trust-bar">
      <span class="trust-label">{copy.trustTitle}</span>
      <div class="trust-pills">
        {copy.trustItems.map((item) => <span class="trust-pill">{item}</span>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid dark-split">
      <div class="split-copy">
        <span class="badge badge-primary">Problem / Solution</span>
        <h2 class="section-title">{copy.problemTitle}</h2>
        <p class="body-copy">{copy.problemBody}</p>
