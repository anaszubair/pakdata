---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="ds-hero">
    <div class="container ds-hero-grid">
      <div class="ds-copy">
        <span class="badge badge-primary">{copy.badge}</span>
        <h1 class="ds-title">{copy.heroTitle}</h1>
        <p class="ds-lead">{copy.heroLead}</p>
        <p class="ds-body">{copy.heroBody}</p>
        <div class="ds-cta-row">
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-primary btn-lg">{copy.primaryCta}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.secondaryCta}</a>
        </div>
      </div>
      <div class="ds-panel card">
        <div class="ds-panel-head">
          <span>{copy.badge}</span>
          <strong>PDMS</strong>
        </div>
        <div class="ds-metric-grid">
          {copy.metrics.map((metric) => (
            <article class="ds-metric">
              <h3>{metric.title}</h3>
              <p>{metric.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.badge}</span>
        <h2 class="section-title">{copy.solutionsTitle}</h2>
      </div>
      <p class="body-copy section-intro">{copy.solutionsBody}</p>
      <div class="solution-grid">
        {copy.solutions.map((item) => (
          <article class="solution-card card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <div class="chip-grid">
              {item.features.map((feature) => <span class="chip">{feature}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.badge}</span>
        <h2 class="section-title">{copy.servicesTitle}</h2>
      </div>
      <p class="body-copy section-intro">{copy.servicesBody}</p>
      <div class="service-grid">
        {copy.serviceBlocks.map((service) => (
          <article class="service-block card">
            <h3>{service.title}</h3>
            <p>{service.body}</p>
            <div class="chip-grid">
              {service.items.map((item) => <span class="chip">{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">{copy.aboutTitle}</span>
        <h2 class="section-title">{copy.aboutTitle}</h2>
        <p class="body-copy">{copy.aboutBody}</p>
        <p class="body-copy">{copy.storyBody}</p>
      </div>
      <div class="values-card card">
        <h3>{copy.valuesTitle}</h3>
        <div class="chip-grid">
          {copy.values.map((value) => <span class="chip">{value}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container cta-band card">
      <div>
        <h2 class="section-title">{copy.contactTitle}</h2>
        <p class="body-copy">{copy.contactBody}</p>
      </div>
      <div class="ds-cta-row">
        <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.cta}</a>
        <a href={getRelativeLocaleUrl(lang, '/faq')} class="btn btn-outline btn-lg">FAQ</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .ds-hero {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, #fefbf8, #fff);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 3.5rem;
  }

  .ds-hero-grid,
  .split-grid {
    display: grid;
    gap: 1.5rem;
    align-items: center;
  }

  .ds-hero-grid {
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, .92fr);
  }

  .ds-title {
    color: var(--primary);
    font-size: clamp(2.1rem, 3vw, 3rem);
    line-height: 1.04;
    margin: .85rem 0 .9rem;
  }

  .ds-lead {
    color: var(--dark);
    font-weight: 700;
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    margin-bottom: .9rem;
  }

  .ds-body,
  .body-copy,
  .section-intro {
    color: var(--secondary-dark);
    line-height: 1.7;
    max-width: 46rem;
  }

  .ds-cta-row,
  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .ds-panel {
    padding: 1.25rem;
    background: #fff;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
    border-radius: 1rem;
  }

  .ds-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    color: var(--dark);
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .8rem;
    font-weight: 700;
  }

  .ds-metric-grid,
  .solution-grid,
  .service-grid {
    display: grid;
    gap: 1rem;
  }

  .ds-metric-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .ds-metric,
  .solution-card,
  .service-block,
  .values-card,
  .cta-band {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .ds-metric,
  .solution-card,
  .service-block {
    padding: 1.1rem;
  }

  .ds-metric h3,
  .solution-card h3,
  .service-block h3,
  .values-card h3 {
    margin-bottom: .55rem;
    color: var(--dark);
    font-size: 1.02rem;
  }

  .ds-metric p,
