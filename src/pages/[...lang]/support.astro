---

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


const title = t('support.seo.title');
const description = t('support.seo.desc');

const faqCategories = [
  {
    id: "notifications",
    title: t('support.faq.notifications.title'),
    icon: "🔔",
    faqs: [
      {
        q: t('support.faq.notifications.q1'),
        a: t('support.faq.notifications.a1')
      },
      {
        q: t('support.faq.notifications.q2'),
        a: t('support.faq.notifications.a2')
      }
    ]
  },
  {
    id: "payments",
    title: t('support.faq.payments.title'),
    icon: "💳",
    faqs: [
      {
        q: t('support.faq.payments.q1'),
        a: t('support.faq.payments.a1')
      },
      {
        q: t('support.faq.payments.q2'),
        a: t('support.faq.payments.a2')
      }
    ]
  },
  {
    id: "technical",
    title: t('support.faq.technical.title'),
    icon: "🛠️",
    faqs: [
      {
        q: t('support.faq.technical.q1'),
        a: t('support.faq.technical.a1')
      },
      {
        q: t('support.faq.technical.q2'),
        a: t('support.faq.technical.a2')
      }
    ]
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="support-hero">
    <div class="container text-center animate-fade-in">
      <span class="badge badge-primary">{t('support.hero.badge')}</span>
      <h1 class="support-hero-title">{t('support.hero.title')}</h1>
      <p class="support-hero-subtitle">
        {t('support.hero.subtitle')}
      </p>
    </div>
  </section>

  <!-- FAQ Section with Accordions -->
  <section class="section">
    <div class="container grid grid-2">
      <!-- FAQ Accordions Column -->
      <div class="faqs-column">
        <h2 class="faq-section-title">{t('support.faq.title')}</h2>
        
        {faqCategories.map(cat => (
          <div class="faq-category-group" id={cat.id}>
            <h3 class="category-header">
              <span class="cat-icon">{cat.icon}</span>
              <span>{cat.title}</span>
            </h3>
            
            <div class="accordions-wrap">
              {cat.faqs.map(faq => (
                <div class="accordion-item">
                  <button class="accordion-trigger">
                    <span class="question-text">{faq.q}</span>
                    <span class="plus-icon">+</span>
                  </button>
                  <div class="accordion-panel">
                    <div class="panel-content">
                      {faq.a.split('\n').map(line => (
                        <p>{line}</p>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Support Form Column -->
      <div class="support-form-column">
        <div class="support-ticket-card card">
          <h3 class="form-card-title">{t('support.ticket.title')}</h3>
          <p class="form-card-subtitle">{t('support.ticket.subtitle')}</p>
          
          <form class="ticket-form" id="support-ticket-form" data-alert-msg={t('support.ticket.alert')} data-default-name={t('support.ticket.defaultName')}>
            <div class="form-group">
              <label class="form-label" for="ticket-name">{t('support.ticket.name.label')}</label>
              <input type="text" id="ticket-name" required class="form-control" placeholder={t('support.ticket.name.placeholder')} />
            </div>

            <div class="form-group">
              <label class="form-label" for="ticket-email">{t('support.ticket.email.label')}</label>
              <input type="email" id="ticket-email" required class="form-control" placeholder={t('support.ticket.email.placeholder')} />
            </div>

            <div class="form-group grid grid-2" style="gap: 1rem; margin-bottom: 0;">
              <div class="form-group">
                <label class="form-label" for="ticket-app">{t('support.ticket.app.label')}</label>
                <select id="ticket-app" required class="form-control">
                  <option value="quran-majeed">{t('support.ticket.app.qm')}</option>
                  <option value="quran-pak">{t('support.ticket.app.qp')}</option>
                  <option value="easyurdu">{t('support.ticket.app.eu')}</option>
                  <option value="quran-tv">{t('support.ticket.app.qt')}</option>
                  <option value="other">{t('support.ticket.app.other')}</option>
                </select>
              </div>
              
              <div class="form-group">
                <label class="form-label" for="ticket-device">{t('support.ticket.device.label')}</label>
                <select id="ticket-device" required class="form-control">
                  <option value="ios">{t('support.ticket.device.ios')}</option>
                  <option value="android">{t('support.ticket.device.android')}</option>
                  <option value="macos">{t('support.ticket.device.macos')}</option>
                  <option value="smart-tv">{t('support.ticket.device.tv')}</option>
                  <option value="web">{t('support.ticket.device.web')}</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="ticket-msg">{t('support.ticket.msg.label')}</label>
              <textarea id="ticket-msg" required class="form-control" placeholder={t('support.ticket.msg.placeholder')}></textarea>
            </div>

            <button type="submit" class="btn btn-primary w-100" id="submit-ticket-btn">{t('support.ticket.btn')}</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg text-center">
    <div class="container max-width-600">
      <h2 class="direct-email-title">{t('support.urgent.title')}</h2>
      <p class="direct-email-desc">
        {t('support.urgent.desc')}
      </p>
      <a href="mailto:support@pakdata.com" class="btn btn-outline" id="support-email-btn">{t('support.urgent.btn')}</a>
    </div>
  </section>
</Layout>

<style>
  .support-hero {
    text-align: center;
    background: radial-gradient(at 20% 0%,oklch(97% .04 60) 0%,transparent 50%),radial-gradient(at 80% 20%,oklch(96% .03 220) 0%,transparent 50%),linear-gradient(180deg,oklch(99% .005 80),oklch(100% 0 0));
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .support-hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .support-hero-subtitle {
    font-size: calc(1.25rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* FAQs columns */
  .faq-section-title {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .faq-category-group {
    margin-bottom: 2.5rem;
  }

  .category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 1.25rem;
    border-bottom: 2px solid var(--border-focus);
    padding-bottom: 0.5rem;
  }

  .cat-icon {
    font-size: calc(1.5rem * var(--text-scale, 1));
  }

  /* Accordions */
  .accordions-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .accordion-item {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background-color: var(--light);
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }

  .accordion-item:hover {
    border-color: var(--primary-light);
  }

  .accordion-trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 1rem 1.25rem;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    font-weight: 400;
    color: var(--dark-soft);
    font-size: calc(0.9375rem * var(--text-scale, 1));
    gap: 1rem;
  }

  .accordion-trigger:hover {
    color: var(--primary);
  }

  .plus-icon {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 400;
    color: var(--secondary);
    transition: transform var(--transition-normal);
  }

  .accordion-item.active {
    border-color: var(--primary);
  }

  .accordion-item.active .plus-icon {
    transform: rotate(45deg);
    color: var(--primary);
  }

  .accordion-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal) ease-out;
  }

  .panel-content {
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: var(--secondary-dark);
    font-size: calc(0.9375rem * var(--text-scale, 1));
    line-height: 1.6;
    border-top: 1px solid var(--light-soft);
  }

  .panel-content p {
    margin-bottom: 0.75rem;
  }

  .panel-content p:last-child {
    margin-bottom: 0;
  }

  /* Ticket Form Column */
  .support-form-column {
    position: sticky;
    top: 6rem;
    align-self: start;
  }

  .support-ticket-card {
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
  }

  .form-card-title {
    font-size: calc(1.25rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .form-card-subtitle {
    font-size: calc(0.875rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    margin-bottom: 2rem;
  }

  .w-100 {
    width: 100%;
  }

  .max-width-600 {
    max-width: 600px;
    margin: 0 auto;
  }

  .direct-email-title {
    font-size: calc(1.5rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .direct-email-desc {
    color: var(--secondary-dark);
    margin-bottom: 1.5rem;
  }

  /* On mobile, support ticket form is not sticky */
  @media (max-width: 767px) {
    .support-form-column {
      position: static;
    }
  }

  @media (min-width: 640px) {
    .support-hero-title {
      font-size: calc(2.5rem * var(--text-scale, 1));
    }
  }

  @media (min-width: 768px) {
    .support-hero-title {
      font-size: calc(3rem * var(--text-scale, 1));
    }
  }
</style>

<!-- Accordion Toggle JavaScript -->
<script>
  const accordions = document.querySelectorAll('.accordion-item');
  const ticketForm = document.getElementById('support-ticket-form');

  if (accordions.length > 0) {
    accordions.forEach(item => {
      const trigger = item.querySelector('.accordion-trigger');
      const panel = item.querySelector('.accordion-panel') as HTMLDivElement;

      trigger?.addEventListener('click', () => {
        const isActive = item.classList.contains('active');

        // Close all other accordions in the same category optionally, or just close others
        accordions.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('active');
            const otherPanel = otherItem.querySelector('.accordion-panel') as HTMLDivElement;
            if (otherPanel) otherPanel.style.maxHeight = '0';
          }
        });

        // Toggle current accordion
        if (isActive) {
          item.classList.remove('active');
          panel.style.maxHeight = '0';
        } else {
          item.classList.add('active');
          panel.style.maxHeight = panel.scrollHeight + 'px';
        }
      });
    });
  }

  if (ticketForm) {
    ticketForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const ticketName = document.getElementById('ticket-name') as HTMLInputElement;
      const defaultName = ticketForm.dataset.defaultName || 'User';
      const alertMsg = ticketForm.dataset.alertMsg || '';
      const submitButton = document.getElementById('submit-ticket-btn') as HTMLButtonElement;

      submitButton.disabled = true;

      try {
        const response = await fetch('/api/send-email', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            formType: 'support',
            fields: {
              name: ticketName?.value || defaultName,
              email: (document.getElementById('ticket-email') as HTMLInputElement)?.value,
              app: (document.getElementById('ticket-app') as HTMLSelectElement)?.value,
              device: (document.getElementById('ticket-device') as HTMLSelectElement)?.value,
              message: (document.getElementById('ticket-msg') as HTMLTextAreaElement)?.value
            }
          })
        });

        if (!response.ok) throw new Error('Email request failed');

        alert(`${ticketName?.value || defaultName}: ${alertMsg}`);
        ticketForm.reset();
      } catch {
        alert('Sorry, your support request could not be sent right now. Please try again or email support directly.');
      } finally {
        submitButton.disabled = false;
      }
    });
  }
</script>
