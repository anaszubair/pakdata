    tagline: t('home.products.eu.tagline'),
    description: t('home.products.eu.desc'),
    badge: t('home.products.eu.badge'),
    rating: "4.8",
    downloads: t('home.products.eu.downloads'),
    platforms: ["iOS", "Android"],
    features: [
      t('home.products.eu.f1'),
      t('home.products.eu.f2'),
      t('home.products.eu.f3'),
      t('home.products.eu.f4')
    ],
    detailsUrl: getRelativeLocaleUrl(lang, '/products/easyurdu'),
    imageUrl: "/images/easyUrdu.webp"
  }
];

const heroCarouselSlides = [
  {
    id: "quran-majeed",
    label: t('products.items.qm.name'),
    image: "/images/quranscreen.webp",
    note: t('products.items.qm.tagline'),
    downloads: '100M+',
    activeUsers: '30M+',
    awardName: t('home.awards.a1.name'),
    awardCategory: t('home.awards.a1.category')
  },
  {
