---

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'ur' } },
    { params: { lang: 'ar' } }
  ];
}
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


// SEO details
const title = t('home.seo.title');
const description = t('home.seo.desc');

// Featured products data
const featuredProducts = [
  {
    id: "quran-majeed",
    name: t('home.products.qm.name'),
    tagline: t('home.products.qm.tagline'),
    description: t('home.products.qm.desc'),
    badge: t('home.products.qm.badge'),
    rating: "4.8",
    downloads: t('home.products.qm.downloads'),
    platforms: ["iOS", "Android", "macOS", "Web", "TV"],
    features: [
      t('home.products.qm.f1'),
      t('home.products.qm.f2'),
      t('home.products.qm.f3'),
      t('home.products.qm.f4')
    ],
    detailsUrl: getRelativeLocaleUrl(lang, '/products/quran-majeed'),
    imageUrl: "/images/QM.png"
  },
  {
    id: "quran-pak",
    name: t('home.products.qp.name'),
    tagline: t('home.products.qp.tagline'),
    description: t('home.products.qp.desc'),
    badge: t('home.products.qp.badge'),
    rating: "4.7",
    downloads: t('home.products.qp.downloads'),
    platforms: ["iOS", "Android"],
    features: [
      t('home.products.qp.f1'),
      t('home.products.qp.f2'),
      t('home.products.qp.f3'),
      t('home.products.qp.f4')
    ],
    detailsUrl: getRelativeLocaleUrl(lang, '/products/quran-pak'),
    imageUrl: "/images/QP.webp"
  },
  {
    id: "quran-tv",
    name: t('home.products.qt.name'),
    tagline: t('home.products.qt.tagline'),
    description: t('home.products.qt.desc'),
    badge: t('home.products.qt.badge'),
    rating: "4.6",
    downloads: t('home.products.qt.downloads'),
    platforms: ["Android", "TV", "Web"],
    features: [
      t('home.products.qt.f1'),
      t('home.products.qt.f2'),
      t('home.products.qt.f3'),
      t('home.products.qt.f4')
    ],
    detailsUrl: "/products#quran-tv",
    imageUrl: "/images/quranTV.webp"
  },
  {
    id: "easy-urdu",
    name: t('home.products.eu.name'),
    tagline: t('home.products.eu.tagline'),
    description: t('home.products.eu.desc'),
    badge: t('home.products.eu.badge'),
    rating: "4.8",
    downloads: t('home.products.eu.downloads'),
    platforms: ["iOS", "Android"],
    features: [
      t('home.products.eu.f1'),
      t('home.products.eu.f2'),
      t('home.products.eu.f3'),
      t('home.products.eu.f4')
    ],
    detailsUrl: "/products#easy-urdu",
    imageUrl: "/images/easyUrdu.webp"
  }
];
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-container grid grid-2">
      <div class="hero-content animate-fade-in">
        <span class="hero-badge">{t('home.hero.badge')}</span>
        <h1 class="hero-title">{t('home.hero.title')} <span class="text-gradient">{t('home.hero.title.highlight')}</span></h1>
        <p class="hero-subtext">
          {t('home.hero.subtext')}
        </p>
        <div class="hero-actions">
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-primary btn-lg" id="hero-products-btn">{t('home.hero.btn.products')}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-secondary btn-lg" id="hero-contact-btn">{t('home.hero.btn.contact')}</a>
        </div>
      </div>
      
      <!-- Visual Illustration Grid -->
      <div class="hero-visual animate-fade-in">
        <div class="visual-card main-visual">
          <div class="dots-bg"></div>
          <div class="glow-effect"></div>
          <div class="phone-mockup">
            <div class="screen-header">
              <div class="logo-wrap mini-logo">
                <img src="/images/logo.png" alt="PDMS Logo" class="logo-img" />
                <span class="logo-title">{t('home.mock.logo.title')}</span>
              </div>
              <span class="badge badge-success">4.8 ★</span>
            </div>
            <div class="screen-body">
              <div class="mock-ayah">
                <p class="arabic-text">{t('home.mock.ayah.arabic')}</p>
                <p class="trans-text">{t('home.mock.ayah.trans')}</p>
              </div>
              <div class="mock-stats">
                <div class="stat-pill">{t('home.mock.stats.users')}</div>
                <div class="stat-pill">{t('home.mock.stats.apps')}</div>
              </div>
            </div>
          </div>
          
          <!-- Micro Cards floating around -->
          <div class="floating-card pos-1">
            <span class="icon">🏆</span>
            <div>
              <span class="title">{t('home.floating.pasha.title')}</span>
              <span class="desc">{t('home.floating.pasha.desc')}</span>
            </div>
          </div>
          
          <div class="floating-card pos-2">
            <span class="icon">💬</span>
            <div>
              <span class="title">{t('home.floating.eu.title')}</span>
              <span class="desc">{t('home.floating.eu.desc')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="wave-shape">
      <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V0C26.9,8.75,57.05,18.3,87.43,26.24,152.37,43.25,221.71,68.86,321.39,56.44Z" fill="#ffffff"></path>
      </svg>
    </div>
  </section>

  <!-- Trust Metrics Section -->
  <section class="metrics-section">
  <div class="container">
    <div class="metrics-card-grid">

      <div class="metric-card">
        <span class="metric-number" data-target="150">0</span><span class="suffix">{t('home.metrics.downloads.suffix') || 'M+'}</span>
        <span class="metric-title">{t('home.metrics.downloads.title')}</span>
        <span class="metric-desc">{t('home.metrics.downloads.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="45">0</span><span class="suffix">{t('home.metrics.years.suffix') || '+ Yrs'}</span>
        <span class="metric-title">{t('home.metrics.years.title')}</span>
        <span class="metric-desc">{t('home.metrics.years.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="50">0</span><span class="suffix">{t('home.metrics.apps.suffix') || '+'}</span>
        <span class="metric-title">{t('home.metrics.apps.title')}</span>
        <span class="metric-desc">{t('home.metrics.apps.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="45">0</span><span class="suffix">{t('home.metrics.clients.suffix') || '+'}</span>
        <span class="metric-title">{t('home.metrics.clients.title')}</span>
        <span class="metric-desc">{t('home.metrics.clients.desc')}</span>
      </div>

    </div>
  </div>
</section>

  <!-- Featured Products Section -->
  <section class="section section-bg" id="featured-products">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('home.portfolio.badge')}</span>
        <h2 class="section-title">{t('home.portfolio.title')}</h2>
        <p class="section-subtitle">{t('home.portfolio.subtitle')}</p>
      </div>

      <div class="grid grid-2">
        {featuredProducts.map(product => (
          <ProductCard {...product} />
        ))}
      </div>
      
      <div class="section-actions">
        <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-outline" id="view-all-products-btn">{t('home.portfolio.btn')}</a>
      </div>
    </div>
  </section>

  <!-- About Us Summary -->
  <section class="section about-summary-section">
    <div class="container grid grid-2">
      <div class="about-summary-visual">
        <div class="grid grid-2 collage-grid">
          <div class="collage-item box-orange">
            <span class="num">{t('home.about.badge1.num')}</span>
            <span class="lbl">{t('home.about.badge1.lbl')}</span>
          </div>
          <div class="collage-item box-gray">
            <span class="num">{t('home.about.badge2.num')}</span>
            <span class="lbl">{t('home.about.badge2.lbl')}</span>
          </div>
          <div class="collage-item box-light">
            <span class="num">{t('home.about.badge3.num')}</span>
            <span class="lbl">{t('home.about.badge3.lbl')}</span>
          </div>
          <div class="collage-item box-dark">
            <span class="num">{t('home.about.badge4.num')}</span>
            <span class="lbl">{t('home.about.badge4.lbl')}</span>
          </div>
        </div>
      </div>
      
      <div class="about-summary-content">
        <span class="badge badge-primary">{t('home.about.badge')}</span>
        <h2 class="about-title">{t('home.about.title')}</h2>
        <p class="about-p">
          {t('home.about.p1')}
        </p>
        <p class="about-p">
          {t('home.about.p2')}
        </p>
        
        <div class="why-list">
          <div class="why-item">
            <div class="why-icon">🛡️</div>
            <div>
              <h4 class="why-title">{t('home.about.why1.title')}</h4>
              <p class="why-text">{t('home.about.why1.desc')}</p>
            </div>
          </div>
          
          <div class="why-item">
            <div class="why-icon">🌐</div>
            <div>
              <h4 class="why-title">{t('home.about.why2.title')}</h4>
              <p class="why-text">{t('home.about.why2.desc')}</p>
            </div>
          </div>
          
          <div class="why-item">
            <div class="why-icon">🚀</div>
            <div>
              <h4 class="why-title">{t('home.about.why3.title')}</h4>
              <p class="why-text">{t('home.about.why3.desc')}</p>
            </div>
          </div>
        </div>

        <a href={getRelativeLocaleUrl(lang, '/about')} class="btn btn-primary" id="learn-more-about-btn">{t('home.about.btn')}</a>
      </div>
    </div>
  </section>

  <!-- Awards & Recognition -->
  <section class="section section-bg awards-section">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('home.awards.badge')}</span>
        <h2 class="section-title">{t('home.awards.title')}</h2>
        <p class="section-subtitle">{t('home.awards.subtitle')}</p>
      </div>

      <div class="awards-grid">
        <div class="award-card">
          <div class="award-trophy">🏆</div>
          <h3 class="award-name">{t('home.awards.a1.name')}</h3>
          <p class="award-category">{t('home.awards.a1.category')}</p>
          <span class="award-desc">{t('home.awards.a1.desc')}</span>
        </div>
        <div class="award-card">
          <div class="award-trophy">⭐</div>
          <h3 class="award-name">{t('home.awards.a2.name')}</h3>
          <p class="award-category">{t('home.awards.a2.category')}</p>
          <span class="award-desc">{t('home.awards.a2.desc')}</span>
        </div>
        <div class="award-card">
          <div class="award-trophy">📈</div>
          <h3 class="award-name">{t('home.awards.a3.name')}</h3>
          <p class="award-category">{t('home.awards.a3.category')}</p>
          <span class="award-desc">{t('home.awards.a3.desc')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Partnerships / Logos Grid -->
  <section class="section partner-logos-section">
    <div class="container">
      <h3 class="partner-title">{t('home.partners.title')}</h3>
      <div class="partners-grid">
        <div class="partner-logo">{t('home.partners.google')}</div>
        <div class="partner-logo">{t('home.partners.apple')}</div>
        <div class="partner-logo">{t('home.partners.nadra')}</div>
        <div class="partner-logo">{t('home.partners.kfqc')}</div>
        <div class="partner-logo">{t('home.partners.nara')}</div>
        <div class="partner-logo">{t('home.partners.pasha')}</div>
      </div>
    </div>
  </section>

  <!-- Call To Action -->
  <section class="cta-section">
    <div class="container cta-container">
      <div class="cta-content">
        <h2 class="cta-title">{t('home.cta.title')}</h2>
        <p class="cta-desc">
          {t('home.cta.desc')}
        </p>
        <div class="cta-actions">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg btn-white-text" id="cta-contact-btn">{t('home.cta.btn.contact')}</a>
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-secondary btn-lg btn-white-border" id="cta-products-btn">{t('home.cta.btn.products')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero section styles */
  .hero-section {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, oklch(99% .005 80), oklch(100% 0 0));
    padding: 6rem 0 8rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background-color: var(--primary-light);
    color: var(--primary);
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--border-focus);
  }

  .hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero-subtext {
    font-size: calc(1.125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Hero visual phone mockup */
  .hero-visual {
    display: none; /* Hidden on mobile to save space */
    justify-content: center;
    position: relative;
  }

  .main-visual {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 2rem;
    width: 320px;
    height: 480px;
    padding: 1.5rem;
    box-shadow: var(--shadow-xl);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: visible;
  }

  .dots-bg {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    background-image: radial-gradient(var(--secondary) 1.5px, transparent 1.5px);
    background-size: 10px 10px;
    opacity: 0.3;
    z-index: -1;
  }

  .glow-effect {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(236, 103, 36, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
    z-index: -1;
  }

  .phone-mockup {
    border: 2px solid var(--border);
    border-radius: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background-color: var(--light-soft);
  }

  .screen-header {
    background-color: var(--light);
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mini-logo {
    gap: 0.35rem;
  }

  .mini-logo .logo-img {
    height: 1.25rem;
  }

  .mini-logo .logo-title {
    font-size: calc(0.8125rem * var(--text-scale, 1));
  }

  .screen-body {
    flex-grow: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .mock-ayah {
    text-align: center;
    background-color: var(--light);
    padding: 1.25rem 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    margin-top: 1rem;
  }

  .arabic-text {
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-family: Arial, sans-serif;
    color: var(--dark);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .trans-text {
    font-size: calc(0.75rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.4;
  }

  .mock-stats {
    display: flex;
    gap: 0.5rem;
  }

  .stat-pill {
    flex: 1;
    text-align: center;
    background-color: var(--primary-light);
    color: var(--primary);
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 700;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border-focus);
  }

  /* Floating micro-cards */
  .floating-card {
    position: absolute;
    background-color: var(--light);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 10;
  }

  .floating-card .icon {
    font-size: calc(1.5rem * var(--text-scale, 1));
  }

  .floating-card .title {
    display: block;
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 800;
    color: var(--dark);
  }

  .floating-card .desc {
    display: block;
    font-size: calc(0.6875rem * var(--text-scale, 1));
    color: var(--secondary-dark);
  }

  .pos-1 {
    top: 15%;
    left: -60px;
    animation: float1 4s ease-in-out infinite alternate;
  }

  .pos-2 {
    bottom: 15%;
    right: -60px;
    animation: float2 4s ease-in-out infinite alternate;
  }

  @keyframes float1 {
    from { transform: translateY(0); }
    to { transform: translateY(-10px); }
  }

  @keyframes float2 {
    from { transform: translateY(0); }
    to { transform: translateY(10px); }
  }

  .wave-shape {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .wave-shape svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 60px;
  }

  /* Metrics Section */
  .metrics-section {
    padding: 2rem 0;
    margin-top: -3.5rem;
    position: relative;
    z-index: 20;
  }

  .metrics-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    background-color: var(--light);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .metric-card {
    text-align: center;
    padding: 1rem;
  }

  .metric-card:not(:last-child) {
    border-bottom: 1px solid var(--border);
  }

  .metric-number {
    display: block;
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--primary);
    line-height: 1.2;
    margin-bottom: 0.25rem;
    font-family: var(--font-heading);
  }

  .metric-number {
    display: inline-block;
  }

  .suffix {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--primary);
    margin-left: 2px;
  }

  .metric-title {
    display: block;
    font-size: calc(1rem * var(--text-scale, 1));
    font-weight: 500;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .metric-desc {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.5;
  }

  .section-actions {
    display: flex;
    justify-content: center;
    margin-top: 3.5rem;
  }

  /* Collage grid for about section */
  .collage-grid {
    gap: 1rem;
    height: 100%;
  }

  .collage-item {
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .collage-item .num {
    font-size: calc(1.75rem * var(--text-scale, 1));
    font-weight: 600;
    margin-bottom: 0.25rem;
    font-family: var(--font-heading);
  }

  .collage-item .lbl {
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .box-orange {
    background-color: var(--primary);
    color: var(--light);
  }

  .box-gray {
    background-color: var(--secondary-light);
    color: var(--dark);
    border: 1px solid var(--border);
  }

  .box-light {
    background-color: var(--light);
    color: var(--primary);
    border: 1px solid var(--border-focus);
  }

  .box-dark {
    background-color: var(--dark);
    color: var(--light);
  }

  /* About summary content */
  .about-title {
    font-size: calc(1.875rem * var(--text-scale, 1));
    font-weight: 600;
