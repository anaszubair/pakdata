---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container hero-container grid grid-2">
      <div class="hero-content animate-fade-in">
        <span class="hero-badge">{t('home.hero.badge')}</span>
        <h1 class="hero-title">{t('home.hero.title')} <span class="text-gradient">{t('home.hero.title.highlight')}</span></h1>
        <p class="hero-subtext">
          {t('home.hero.subtext')}
        </p>
        <div class="hero-actions">
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-primary btn-lg" id="hero-products-btn">{t('home.hero.btn.products')}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-secondary btn-lg" id="hero-contact-btn">{t('home.hero.btn.contact')}</a>
        </div>
      </div>
      
      <!-- Visual Illustration Grid -->
      <div class="hero-visual animate-fade-in">
        <div class="visual-card main-visual hero-carousel-shell" data-hero-carousel>
          <div class="dots-bg"></div>
          <div class="glow-effect"></div>

          <div class="hero-carousel">
            <div class="hero-carousel-viewport">
              <div class="hero-carousel-track">
                {heroCarouselSlides.map((slide, index) => (
                  <figure
                    class={`hero-carousel-slide ${index === 0 ? 'is-active' : ''}`}
                    data-slide={index}
                    aria-label={slide.label}
                  >
                    <img src={slide.image} alt={slide.label} class="hero-carousel-image" />
                  </figure>
                ))}
              </div>
              <div class="hero-carousel-footer">
                <div class="hero-carousel-dots" aria-label="App screenshot carousel controls">
                  {heroCarouselSlides.map((slide, index) => (
                    <button
                      type="button"
                      class={`hero-carousel-dot ${index === 0 ? 'is-active' : ''}`}
                      data-carousel-dot={index}
                      aria-label={`Show ${slide.label}`}
                    />
                  ))}
                </div>
                <div class="hero-carousel-controls">
                  <button type="button" class="hero-carousel-btn" data-carousel-prev aria-label="Previous screenshot">‹</button>
                  <button type="button" class="hero-carousel-btn" data-carousel-next aria-label="Next screenshot">›</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </section>

  <!-- Trust Metrics Section -->
  <section class="metrics-section">
  <div class="container">
    <div class="metrics-card-grid">

      <div class="metric-card">
        <span class="metric-number" data-target="150">0</span><span class="suffix">{t('home.metrics.downloads.suffix') || 'M+'}</span>
        <span class="metric-title">{t('home.metrics.downloads.title')}</span>
        <span class="metric-desc">{t('home.metrics.downloads.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="45">0</span><span class="suffix">{t('home.metrics.years.suffix') || '+ Yrs'}</span>
        <span class="metric-title">{t('home.metrics.years.title')}</span>
        <span class="metric-desc">{t('home.metrics.years.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="50">0</span><span class="suffix">{t('home.metrics.apps.suffix') || '+'}</span>
        <span class="metric-title">{t('home.metrics.apps.title')}</span>
        <span class="metric-desc">{t('home.metrics.apps.desc')}</span>
      </div>

      <div class="metric-card">
        <span class="metric-number" data-target="45">0</span><span class="suffix">{t('home.metrics.clients.suffix') || '+'}</span>
        <span class="metric-title">{t('home.metrics.clients.title')}</span>
        <span class="metric-desc">{t('home.metrics.clients.desc')}</span>
      </div>

    </div>
  </div>
</section>

  <!-- Featured Products Section -->
  <section class="section section-bg" id="featured-products">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('home.portfolio.badge')}</span>
        <h2 class="section-title">{t('home.portfolio.title')}</h2>
        <p class="section-subtitle">{t('home.portfolio.subtitle')}</p>
      </div>

      <div class="grid grid-2">
        {featuredProducts.map(product => (
          <ProductCard {...product} />
        ))}
      </div>
      
      <div class="section-actions">
        <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-outline" id="view-all-products-btn">{t('home.portfolio.btn')}</a>
      </div>
    </div>
  </section>

  <!-- About Us Summary -->
  <section class="section about-summary-section">
    <div class="container grid grid-2">
      <div class="about-summary-visual">
        <div class="grid grid-2 collage-grid">
          <div class="collage-item box-orange">
            <span class="num">{t('home.about.badge1.num')}</span>
            <span class="lbl">{t('home.about.badge1.lbl')}</span>
          </div>
          <div class="collage-item box-gray">
            <span class="num">{t('home.about.badge2.num')}</span>
            <span class="lbl">{t('home.about.badge2.lbl')}</span>
          </div>
          <div class="collage-item box-light">
            <span class="num">{t('home.about.badge3.num')}</span>
            <span class="lbl">{t('home.about.badge3.lbl')}</span>
          </div>
          <div class="collage-item box-dark">
            <span class="num">{t('home.about.badge4.num')}</span>
            <span class="lbl">{t('home.about.badge4.lbl')}</span>
          </div>
        </div>
      </div>
      
      <div class="about-summary-content">
        <span class="badge badge-primary">{t('home.about.badge')}</span>
        <h2 class="about-title">{t('home.about.title')}</h2>
        <p class="about-p">
          {t('home.about.p1')}
        </p>
        <p class="about-p">
          {t('home.about.p2')}
        </p>
        
        <div class="why-list">
          <div class="why-item">
            <div class="why-icon">🛡️</div>
            <div>
              <h4 class="why-title">{t('home.about.why1.title')}</h4>
              <p class="why-text">{t('home.about.why1.desc')}</p>
            </div>
          </div>
          
          <div class="why-item">
            <div class="why-icon">🌐</div>
            <div>
              <h4 class="why-title">{t('home.about.why2.title')}</h4>
              <p class="why-text">{t('home.about.why2.desc')}</p>
            </div>
          </div>
          
          <div class="why-item">
            <div class="why-icon">🚀</div>
            <div>
              <h4 class="why-title">{t('home.about.why3.title')}</h4>
              <p class="why-text">{t('home.about.why3.desc')}</p>
            </div>
          </div>
        </div>

        <a href={getRelativeLocaleUrl(lang, '/about-us')} class="btn btn-primary" id="learn-more-about-btn">{t('home.about.btn')}</a>
      </div>
    </div>
  </section>

  <!-- Awards & Recognition -->
  <section class="section section-bg awards-section">
    <div class="container">
      <div class="section-title-wrap">
        <span class="badge badge-primary">{t('home.awards.badge')}</span>
        <h2 class="section-title">{t('home.awards.title')}</h2>
        <p class="section-subtitle">{t('home.awards.subtitle')}</p>
      </div>

      <div class="awards-grid">
        <div class="award-card">
          <div class="award-trophy">🏆</div>
          <h3 class="award-name">{t('home.awards.a1.name')}</h3>
          <p class="award-category">{t('home.awards.a1.category')}</p>
          <span class="award-desc">{t('home.awards.a1.desc')}</span>
        </div>
        <div class="award-card">
          <div class="award-trophy">⭐</div>
          <h3 class="award-name">{t('home.awards.a2.name')}</h3>
          <p class="award-category">{t('home.awards.a2.category')}</p>
          <span class="award-desc">{t('home.awards.a2.desc')}</span>
        </div>
        <div class="award-card">
          <div class="award-trophy">📈</div>
          <h3 class="award-name">{t('home.awards.a3.name')}</h3>
          <p class="award-category">{t('home.awards.a3.category')}</p>
          <span class="award-desc">{t('home.awards.a3.desc')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Partnerships / Logos Grid -->
  <section class="section partner-logos-section">
    <div class="container">
      <h3 class="partner-title">{t('home.partners.title')}</h3>
      <div class="partners-grid">
        <div class="partner-logo">{t('home.partners.google')}</div>
        <div class="partner-logo">{t('home.partners.apple')}</div>
        <div class="partner-logo">{t('home.partners.nadra')}</div>
        <div class="partner-logo">{t('home.partners.kfqc')}</div>
        <div class="partner-logo">{t('home.partners.nara')}</div>
        <div class="partner-logo">{t('home.partners.pasha')}</div>
      </div>
    </div>
  </section>

  <!-- Call To Action -->
  <section class="cta-section">
    <div class="container cta-container">
      <div class="cta-content">
        <h2 class="cta-title">{t('home.cta.title')}</h2>
        <p class="cta-desc">
          {t('home.cta.desc')}
        </p>
        <div class="cta-actions">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg btn-white-text" id="cta-contact-btn">{t('home.cta.btn.contact')}</a>
          <a href={getRelativeLocaleUrl(lang, '/products')} class="btn btn-secondary btn-lg btn-white-border" id="cta-products-btn">{t('home.cta.btn.products')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero section styles */
  .hero-section {
    background:
      radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%),
      radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%),
      linear-gradient(180deg, #fefbf8, #fff);
    padding: 6rem 0 8rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section > * {
    position: relative;
    z-index: 1;
  }

  .hero-container {
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background-color: rgba(255, 255, 255, 0.92);
    color: var(--primary);
    font-size: calc(0.8125rem * var(--text-scale, 1));
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--border-focus);
  }

  .hero-title {
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    color: var(--primary-dark);
    text-shadow: none;
  }

  .hero-subtext {
    font-size: calc(1.125rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 40rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Hero visual phone mockup */
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
    width: 100%;
  }

  .main-visual {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,248,240,0.86));
    border: 1px solid rgba(236, 103, 36, 0.14);
    border-radius: 2rem;
    width: min(320px, 100%);
    aspect-ratio: 9 / 16;
    height: auto;
    padding: 0;
    box-shadow: var(--shadow-xl);
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: visible;
  }

  .main-visual::before {
    content: "";
    position: absolute;
    inset: 0.5rem;
    border-radius: 1.6rem;
    border: 1px solid rgba(236, 103, 36, 0.12);
    pointer-events: none;
  }

  .dots-bg {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    background-image: radial-gradient(var(--light) 1.5px, transparent 1.5px);
    background-size: 10px 10px;
    opacity: 0.3;
    z-index: -1;
  }

  .glow-effect {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(236, 103, 36, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
    z-index: -1;
  }

  .phone-mockup {
    display: none;
  }

  .hero-carousel-shell {
    display: block;
  }

  .hero-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .hero-carousel-viewport {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(255,255,255,0.32);
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(255,248,240,.94));
    box-shadow: var(--shadow-md);
  }

  .hero-carousel-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100%;
    transition: transform 0.45s ease;
    will-change: transform;
    height: 100%;
  }

  .hero-carousel-slide {
    position: relative;
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
  }

  .hero-carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }

  .hero-carousel-footer {
    display: flex;
    justify-content: space-between;
    gap: 0.85rem;
    align-items: center;
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.85rem;
    z-index: 4;
    pointer-events: none;
  }

  .hero-carousel-dots {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    pointer-events: auto;
  }

  .hero-carousel-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    border: none;
    background: rgba(236, 103, 36, 0.2);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .hero-carousel-dot.is-active {
    width: 2rem;
    background: var(--primary);
  }

  .hero-carousel-controls {
    display: flex;
    gap: 0.5rem;
    pointer-events: auto;
  }

  .hero-carousel-btn {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--light);
    color: var(--dark);
    font-size: 1.3rem;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }

  .hero-carousel-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .mini-logo {
    gap: 0.35rem;
  }

  .screen-body {
    flex-grow: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .mock-ayah {
    display: none;
  }

  .arabic-text {
    font-size: calc(1.125rem * var(--text-scale, 1));
    font-family: Arial, sans-serif;
    color: var(--dark);
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .trans-text {
    font-size: calc(0.75rem * var(--text-scale, 1));
    color: var(--secondary-dark);
    line-height: 1.4;
  }

  .mock-stats {
    display: none;
  }

  .stat-pill {
    flex: 1;
    text-align: center;
    background-color: var(--primary-light);
    color: var(--primary);
    font-size: calc(0.75rem * var(--text-scale, 1));
    font-weight: 700;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border-focus);
  }

  /* Floating micro-cards */
  .hero-floating-layer {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }

  .floating-card {
    display: none;
  }

  .wave-shape {
    display: none;
  }

  /* Metrics Section */
  .metrics-section {
    padding: 2rem 0;
    margin-top: -3.5rem;
    position: relative;
    z-index: 20;
  }

  .metrics-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    background-color: var(--light);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .metric-card {
    text-align: center;
    padding: 1rem;
  }

  .metric-card:not(:last-child) {
    border-bottom: 1px solid var(--border);
  }

  .metric-number {
    display: block;
    font-size: calc(2rem * var(--text-scale, 1));
    font-weight: 600;
    color: var(--primary);
    line-height: 1.2;
    margin-bottom: 0.25rem;
