---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="case-hero">
    <div class="container case-hero-grid">
      <div class="case-hero-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="case-hero-title">{copy.heroTitle}</h1>
        <p class="case-hero-lead">{copy.heroLead}</p>
        <p class="case-hero-support">{copy.heroSupport}</p>

        <div class="case-hero-points">
          <div class="hero-point">
            <span class="hero-point-label">Global Quran Access</span>
            <strong>Digital-first distribution</strong>
          </div>
          <div class="hero-point">
            <span class="hero-point-label">Platform</span>
            <strong>Windows Mobile & Pocket PC</strong>
          </div>
          <div class="hero-point">
            <span class="hero-point-label">Focus</span>
            <strong>Authentic Quran content</strong>
          </div>
        </div>

        <div class="case-hero-actions">
          <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-primary btn-lg">{copy.explore}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.contact}</a>
        </div>
      </div>

      <div class="case-hero-visual card">
        <img src="/images/quran-complex-screen1.jpg" alt="King Fahad Quran Printing Complex project visual" class="case-hero-image" />
        <div class="case-hero-overlay">
          <div>
            <span class="overlay-kicker">{copy.heroBadge}</span>
            <strong class="overlay-title">{copy.heroTitle}</strong>
          </div>
          <div class="overlay-meta">Quran accessibility, preservation, and global learning</div>
        </div>
      </div>
    </div>
