      { q: 'هل QuranExplorer مجاني؟', a: 'تم تصميم المنصة كتجربة دراسة قرآن سهلة الوصول ويمكن استخدامها من قبل جمهور واسع عبر الإنترنت.' },
      { q: 'هل يدعم البث الصوتي؟', a: 'نعم، يتضمن بثًا صوتيًا للقرآن عبر الإنترنت مع اختيار القارئ ودعم التشغيل.' },
      { q: 'هل يمكن حفظ الآيات؟', a: 'نعم، كان وضع العلامات وحفظ التقدم جزءًا من سير عمل الدراسة.' }
    ],
    finalTitle: 'اختبر القرآن عبر التكنولوجيا الحديثة',
    finalBody: 'استكشف QuranExplorer واكتشف منصة قرآنية موثوقة عالميًا صُممت للقراءة والاستماع والتعلم والتأمل الروحي.',
    launch: 'تشغيل QuranExplorer',
    more: 'استعرض المزيد من المشاريع',
    footerDesc: 'QuranExplorer هي منصة قرآنية شاملة عبر الإنترنت تقدم التلاوات والترجمات متعددة اللغات والبث الصوتي ودعم التجويد وأدوات دراسة القرآن المتقدمة للمستخدمين حول العالم.'
  }
}[lang];
---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="portal-hero">
    <div class="container portal-grid">
      <div class="portal-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="portal-title">{copy.heroTitle}</h1>
        <p class="portal-lead">{copy.heroLead}</p>
        <p class="portal-support">{copy.heroSupport}</p>
        <div class="portal-stats">
          {copy.heroStats.map((item) => (
            <div class="portal-stat card">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))}
        </div>
        <div class="portal-actions">
          <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-primary btn-lg">{copy.launch}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.more}</a>
        </div>
      </div>

      <div class="portal-visual card">
        <img src="/images/q_explorer_sc.png" alt="QuranExplorer portal visual" class="portal-image" />
        <div class="portal-visual-footer">
          <span>{copy.heroBadge}</span>
          <span>Streaming Quran, translations, and Tajweed</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-grid card">
        <div class="info-row">
          <span class="info-kicker">Audience</span>
          <strong>Global Muslim users</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Platform</span>
          <strong>Online Quran portal</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Focus</span>
          <strong>Learning, recitation, and reflection</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container text-band">
      <span class="badge badge-primary">{copy.reachTitle}</span>
      <h2 class="section-title">{copy.reachTitle}</h2>
      <p class="body-copy">{copy.reachBody}</p>
      <div class="pill-row">
        {copy.reachHighlights.map((item) => (
          <span class="chip">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.featuresTitle}</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>
      <div class="feature-grid">
        {copy.features.map((feature) => (
          <article class="feature-card card">
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.recitersTitle}</span>
        <h2 class="section-title">{copy.recitersTitle}</h2>
        <p class="body-copy">Featuring select reciters and streamed experiences that made Quran study feel immediate and personal.</p>
      </div>
      <div class="reciter-grid">
        {copy.reciters.map((reciter) => (
          <div class="reciter-card card">
            <strong>{reciter}</strong>
            <span>Featured reciter</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.techTitle}</span>
        <h2 class="section-title">{copy.techTitle}</h2>
        <p class="body-copy">{copy.techBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Technology highlights</h3>
        <ul class="check-list">
          {copy.techItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.benefitsTitle}</span>
        <h2 class="section-title">{copy.benefitsTitle}</h2>
        <p class="body-copy">{copy.benefitsBody}</p>
      </div>
      <div class="benefit-panel card">
        <ul class="check-list">
          {copy.benefits.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.whyTitle}</span>
        <h2 class="section-title">{copy.whyTitle}</h2>
        <p class="body-copy">{copy.whyBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Why it stood out</h3>
        <ul class="check-list">
          {copy.whyItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.faqTitle}</span>
        <h2 class="section-title">{copy.faqTitle}</h2>
      </div>
      <div class="faq-grid">
        {copy.faqs.map((faq) => (
          <details class="faq-card card">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section portal-cta">
    <div class="container text-center text-white">
      <h2 class="cta-title">{copy.finalTitle}</h2>
      <p class="cta-desc">{copy.finalBody}</p>
      <div class="cta-actions">
        <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-primary btn-lg btn-white-text">{copy.launch}</a>
        <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg btn-white-text">{copy.more}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .portal-hero {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, #fefbf8, #fff);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 4rem;
  }

  .portal-grid,
  .split-layout {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 2rem;
    align-items: center;
  }

  .split-layout.reverse {
    grid-template-columns: .95fr 1.05fr;
  }

  .portal-title {
    font-size: clamp(2.1rem, 3vw, 3rem);
    line-height: 1.05;
    font-weight: 700;
    color: var(--primary);
    margin: .9rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .portal-lead,
  .portal-support,
  .body-copy {
    color: var(--secondary-dark);
    line-height: 1.7;
    font-size: calc(1.02rem * var(--text-scale, 1));
  }

  .portal-support {
    margin-top: .9rem;
    font-weight: 600;
    color: var(--dark);
  }

  .portal-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .9rem;
    margin: 1.3rem 0 1.35rem;
  }

  .portal-stat {
    padding: 1rem;
  }

  .portal-stat strong {
    display: block;
    font-size: 1.1rem;
    color: var(--dark);
  }

  .portal-stat span {
    display: block;
    margin-top: .35rem;
    color: var(--secondary-dark);
    line-height: 1.4;
  }

  .portal-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    margin-top: 1.3rem;
  }

  .portal-visual,
  .info-grid,
  .list-panel,
  .benefit-panel {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1.2rem;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .portal-visual {
    padding: .9rem;
  }

  .portal-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: .9rem;
  }

  .portal-visual-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: .9rem .2rem .1rem;
    color: var(--secondary-dark);
    font-size: .92rem;
  }

  .section-title {
    font-size: clamp(1.65rem, 2.8vw, 2.65rem);
    line-height: 1.12;
    margin: .7rem 0 .9rem;
    color: var(--dark);
  }

  .section-copy-block,
  .text-band {
    max-width: 42rem;
  }

  .section-title-wrap.tight {
    margin-bottom: 1.3rem;
  }

  .info-grid,
  .list-panel,
  .benefit-panel {
    padding: 1.3rem;
  }

  .info-row {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .info-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .info-kicker {
    display: block;
    font-size: .76rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--primary);
    margin-bottom: .35rem;
  }

  .info-row strong {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--dark);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .feature-card {
    padding: 1.25rem;
  }

  .feature-card h3,
  .panel-title {
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--dark);
    margin-bottom: .65rem;
  }

  .feature-card p {
    color: var(--secondary-dark);
    line-height: 1.6;
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-top: 1rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 2.3rem;
    padding: .45rem .85rem;
    border-radius: 999px;
    background: var(--primary-light);
    color: var(--dark);
    font-weight: 700;
    font-size: .86rem;
  }

  .reciter-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .reciter-card {
    padding: 1.2rem;
  }

  .reciter-card strong {
    display: block;
    color: var(--dark);
    margin-bottom: .25rem;
  }

  .reciter-card span {
    color: var(--secondary-dark);
    font-size: .92rem;
  }

  .check-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: .8rem;
  }

  .check-list li {
    position: relative;
    padding-inline-start: 1.35rem;
    color: var(--secondary-dark);
    line-height: 1.55;
  }

  .check-list li::before {
    content: '•';
    position: absolute;
    inset-inline-start: 0;
    color: var(--primary);
    font-size: 1.2rem;
    line-height: 1;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .faq-card {
    padding: 1.1rem 1.2rem;
  }

  .faq-card summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--dark);
    list-style: none;
  }

  .faq-card summary::-webkit-details-marker {
    display: none;
  }

  .faq-card p {
    margin-top: .8rem;
    color: var(--secondary-dark);
    line-height: 1.65;
  }

  .portal-cta {
    background: linear-gradient(135deg, var(--dark) 0%, #1d2433 100%);
    color: white;
  }

  .cta-title {
    font-size: clamp(1.75rem, 3vw, 3rem);
    line-height: 1.15;
    margin-bottom: .8rem;
  }

  .cta-desc {
    max-width: 44rem;
    margin: 0 auto;
    color: rgba(255,255,255,.84);
    line-height: 1.7;
  }

  .btn-white-text {
    color: white;
  }

  @media (max-width: 1024px) {
    .portal-grid,
    .split-layout,
    .split-layout.reverse {
      grid-template-columns: 1fr;
    }

    .portal-stats,
    .feature-grid,
    .reciter-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .portal-hero {
      padding: 3.5rem 0 3rem;
    }

    .portal-title {
      max-width: none;
    }

    .portal-actions,
    .cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .portal-visual-footer {
      flex-direction: column;
    }
  }
</style>
