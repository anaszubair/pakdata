---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="imagine-hero">
    <div class="container imagine-grid">
      <div class="imagine-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="imagine-title">{copy.heroTitle}</h1>
        <p class="imagine-lead">{copy.heroLead}</p>
        <p class="imagine-support">{copy.heroSupport}</p>
        <div class="imagine-actions">
          <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-primary btn-lg">{copy.explore}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.contact}</a>
        </div>
      </div>
      <div class="imagine-visual card">
        <img src="/images/imagine.jpg" alt="Imagine forensic sketching visual" class="imagine-image" />
        <div class="imagine-visual-footer">
          <span>{copy.heroBadge}</span>
          <span>Sketching, investigation, and reporting</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-grid card">
        <div class="info-row">
          <span class="info-kicker">Client</span>
          <strong>{t('projects.items.imagine.client')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Scale</span>
          <strong>{t('projects.items.imagine.scale')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Focus</span>
          <strong>Digital forensic sketching</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
