---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="nadra-hero">
    <div class="container nadra-grid">
      <div class="nadra-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="nadra-title">{t('projects.items.nadra.title')}</h1>
        <p class="nadra-lead">{copy.heroLead}</p>
        <p class="nadra-support">{copy.heroSupport}</p>
        <div class="nadra-mini-metrics">
          {metrics.map(metric => (
            <div class="nadra-mini-card">
              <span class="nadra-mini-value">{metric.value}</span>
              <span class="nadra-mini-label">{metric.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="nadra-visual card">
        <img src="/images/nadra.jpg" alt="NADRA project visual" class="nadra-image" />
        <div class="nadra-visual-footer">
          <span>{copy.heroBadge}</span>
          <span>{t('projects.items.nadra.scale')}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-panel card">
        <div class="info-row">
          <span class="info-kicker">Client</span>
          <strong>{t('projects.items.nadra.client')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Scale</span>
          <strong>{t('projects.items.nadra.scale')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Impact</span>
          <strong>{t('projects.items.nadra.metric2')}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.challengeTitle}</span>
        <h2 class="section-title">{copy.challengeTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.challengeIntro}</p>
      <div class="bullet-grid">
        {copy.challengeItems.map(item => <div class="bullet-card card">{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid reverse">
      <div class="split-copy">
        <span class="badge badge-primary">{copy.solutionTitle}</span>
        <h2 class="section-title">{copy.solutionTitle}</h2>
        <p class="body-copy">{copy.solutionBody}</p>
      </div>
      <div class="bullet-grid compact">
        {copy.solutionItems.map(item => <div class="bullet-card card">{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-grid">
      <div class="split-copy">
        <span class="badge badge-primary">{copy.techTitle}</span>
        <h2 class="section-title">{copy.techTitle}</h2>
        <p class="body-copy">{copy.techBody}</p>
      </div>
      <div class="chip-grid">
        {techStack.map(item => <div class="chip">{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.scaleTitle}</span>
        <h2 class="section-title">{copy.scaleTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.scaleBody}</p>
      <div class="metrics-grid">
        {copy.scaleItems.map(item => <div class="metric-card card">{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-grid reverse">
      <div class="split-copy">
        <span class="badge badge-primary">{copy.qualityTitle}</span>
        <h2 class="section-title">{copy.qualityTitle}</h2>
        <p class="body-copy">{copy.qualityBody}</p>
      </div>
      <div class="split-copy">
        <span class="badge badge-primary">{copy.whyTitle}</span>
        <h2 class="section-title">{copy.whyTitle}</h2>
        <p class="body-copy">{copy.whyBody}</p>
        <div class="chip-grid">
          {copy.whyItems.map(item => <div class="chip">{item}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section final-cta-band">
    <div class="container final-cta-grid">
      <div>
        <span class="badge badge-primary">{copy.finalTitle}</span>
        <h2 class="section-title">{copy.finalTitle}</h2>
        <p class="body-copy">{copy.finalBody}</p>
        <div class="cta-actions">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.contact}</a>
          <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-outline btn-lg">{copy.projects}</a>
        </div>
      </div>
      <div class="final-art card">
        <img src="/images/nadra.jpg" alt="NADRA project visual" />
        <p>{copy.footerDesc}</p>
      </div>
    </div>
  </section>

  <section class="section footer-summary">
    <div class="container">
      <p>{copy.footerDesc}</p>
    </div>
  </section>
</Layout>

<style>
  .nadra-hero {
