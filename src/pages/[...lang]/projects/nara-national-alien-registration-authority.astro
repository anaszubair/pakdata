---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="nara-hero">
    <div class="container nara-grid">
      <div class="nara-copy">
        <span class="badge badge-primary">{copy.heroBadge}</span>
        <h1 class="nara-title">{copy.heroTitle}</h1>
        <p class="nara-lead">{copy.heroLead}</p>
        <p class="nara-support">{copy.heroSupport}</p>

        <div class="nara-mini-metrics">
          {copy.metrics.map((metric) => (
            <div class="nara-mini-card card">
              <span class="nara-mini-value">{metric.value}</span>
              <span class="nara-mini-label">{metric.label}</span>
            </div>
          ))}
        </div>

        <div class="nara-actions">
          <a href={getRelativeLocaleUrl(lang, '/projects')} class="btn btn-primary btn-lg">{copy.explore}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.contact}</a>
        </div>
      </div>

      <div class="nara-visual card">
        <img src="/images/nara-screenshot-350x316.jpg" alt="NARA biometric registration visual" class="nara-image" />
        <div class="nara-visual-footer">
          <span>{copy.heroBadge}</span>
          <span>Secure identity verification and registration</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.overviewTitle}</span>
        <h2 class="section-title">{copy.overviewTitle}</h2>
        <p class="body-copy">{copy.overviewBody}</p>
      </div>
      <div class="info-grid card">
        <div class="info-row">
          <span class="info-kicker">Client</span>
          <strong>{t('projects.items.nara.client')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Scale</span>
          <strong>{t('projects.items.nara.scale')}</strong>
        </div>
        <div class="info-row">
          <span class="info-kicker">Focus</span>
          <strong>Biometric identity management</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout reverse">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.objectiveTitle}</span>
        <h2 class="section-title">{copy.objectiveTitle}</h2>
        <p class="body-copy">{copy.objectiveBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Objectives</h3>
        <ul class="check-list">
          {copy.objectiveItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.biometricTitle}</span>
        <h2 class="section-title">{copy.biometricTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.biometricBody}</p>
      <div class="feature-grid">
        {copy.biometricItems.map((item) => (
          <article class="feature-card card">
            <h3>{item}</h3>
            <p>Enterprise identity processing and secure verification support.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container split-layout">
      <div class="section-copy-block">
        <span class="badge badge-primary">{copy.enterpriseTitle}</span>
        <h2 class="section-title">{copy.enterpriseTitle}</h2>
        <p class="body-copy">{copy.enterpriseBody}</p>
      </div>
      <div class="list-panel card">
        <h3 class="panel-title">Technology highlights</h3>
        <ul class="check-list">
          {copy.enterpriseItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.securityTitle}</span>
        <h2 class="section-title">{copy.securityTitle}</h2>
      </div>
      <p class="body-copy section-copy">{copy.securityBody}</p>

      <div class="workflow-grid">
