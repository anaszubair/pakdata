    description: t('about.milestone.2018.desc')
  },
    {
    year: "2019",
    title: t('about.milestone.2019.title'),
    description: t('about.milestone.2019.desc')
  }
];

const values = [
  {
    icon: "🤝",
    title: t('about.value.purpose.title'),
    text: t('about.value.purpose.text')
  },
  {
    icon: "📜",
    title: t('about.value.authenticity.title'),
    text: t('about.value.authenticity.text')
  },
  {
    icon: "📈",
