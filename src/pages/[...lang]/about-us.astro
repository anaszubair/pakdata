    title: t('about.milestone.2005.title'),
    description: t('about.milestone.2005.desc')
  },
  {
    year: "2008",
    title: t('about.milestone.2008.title'),
    description: t('about.milestone.2008.desc')
  },
  {
    year: "2010",
    title: t('about.milestone.2010.title'),
    description: t('about.milestone.2010.desc')
  },
  {
    year: "2012",
    title: t('about.milestone.2012.title'),
    description: t('about.milestone.2012.desc')
  },
  {
