    cta: 'ہم سے رابطہ کریں',
    services: [
      {
        key: 'objective-c',
        title: 'Objective C',
        desc: 'نیشٹیو iPhone/iPad اور Mac ایپلیکیشنز کی تیاری میں ہم آپ کے ساتھ ہیں۔'
