---

<Layout title={copy.seoTitle} description={copy.seoDesc}>
  <section class="eb-hero">
    <div class="container eb-hero-grid">
      <div class="eb-copy">
        <span class="badge badge-primary">{copy.badge}</span>
        <h1 class="eb-title">{copy.heroTitle}</h1>
        <p class="eb-lead">{copy.heroLead}</p>
        <p class="eb-body">{copy.heroBody}</p>
        <div class="eb-cta-row">
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.primaryCta}</a>
          <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-outline btn-lg">{copy.secondaryCta}</a>
        </div>
      </div>
      <div class="eb-panel card">
        <div class="eb-trust-row">
          {copy.trustItems.map((item) => <span class="trust-pill">{item}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">{copy.badge}</span>
        <h2 class="section-title">{copy.plansTitle}</h2>
      </div>
      <div class="plan-grid">
        {copy.plans.map((plan) => (
          <article class="plan-card card">
            <span class="plan-badge">{plan.badge}</span>
            <h3>{plan.title}</h3>
            <p>{plan.body}</p>
            <ul>
              {plan.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container eb-process">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Process</span>
        <h2 class="section-title">{copy.processTitle}</h2>
      </div>
      <div class="step-row">
        {copy.process.map((step, idx) => (
          <div class="step-card card">
            <span>{String(idx + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title-wrap tight">
        <span class="badge badge-primary">Features</span>
        <h2 class="section-title">{copy.featuresTitle}</h2>
      </div>
      <div class="feature-pill-grid">
        {copy.features.map((feature) => <span class="feature-pill">{feature}</span>)}
      </div>
    </div>
  </section>

  <section class="section section-bg">
    <div class="container eb-custom card">
      <div>
        <span class="badge badge-primary">Custom</span>
        <h2 class="section-title">{copy.customTitle}</h2>
        <p class="body-copy">{copy.customBody}</p>
      </div>
      <div class="eb-note">
        <strong>Examples</strong>
        <ul>
          <li>Point of sale software</li>
          <li>Multi-vendor B2B functionality</li>
          <li>Unlimited customization</li>
          <li>Advanced report builder</li>
          <li>Push notification integration</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container eb-cta card">
      <div>
        <span class="badge badge-primary">{copy.badge}</span>
        <h2 class="section-title">{copy.ctaTitle}</h2>
        <p class="body-copy">{copy.ctaBody}</p>
      </div>
      <a href={getRelativeLocaleUrl(lang, '/contact')} class="btn btn-primary btn-lg">{copy.finalCta}</a>
    </div>
  </section>
</Layout>

<style>
  .eb-hero {
    background: radial-gradient(at 20% 0%, oklch(97% .04 60) 0%, transparent 50%), radial-gradient(at 80% 20%, oklch(96% .03 220) 0%, transparent 50%), linear-gradient(180deg, #fefbf8, #fff);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 3.5rem;
  }

  .eb-hero-grid,
  .eb-custom,
  .eb-cta {
    display: grid;
    gap: 1.5rem;
    align-items: center;
  }

  .eb-hero-grid {
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, .9fr);
  }

  .eb-title {
    color: var(--primary);
    font-size: clamp(2.2rem, 3vw, 3rem);
    line-height: 1.04;
    margin: .85rem 0 1rem;
  }

  .eb-lead {
    color: var(--dark);
    font-weight: 700;
    line-height: 1.65;
    margin-bottom: .9rem;
  }

  .eb-body,
  .body-copy {
    color: var(--secondary-dark);
    line-height: 1.7;
  }

  .eb-cta-row,
  .eb-trust-row,
  .feature-pill-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .eb-panel,
  .plan-card,
  .step-card,
  .eb-custom,
  .eb-cta {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1rem;
    box-shadow: var(--shadow-sm);
    padding: 1.25rem;
  }

  .trust-pill,
  .plan-badge,
  .feature-pill {
    display: inline-flex;
    align-items: center;
    padding: .6rem .85rem;
    border-radius: 999px;
    background: var(--light-soft);
    border: 1px solid var(--border);
    color: var(--dark);
    font-weight: 600;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .plan-card h3 {
    margin: .75rem 0 .5rem;
    color: var(--dark);
    font-size: 1.1rem;
  }

  .plan-card p,
  .plan-card li {
    color: var(--secondary-dark);
    line-height: 1.65;
  }

  .plan-card ul,
  .eb-note ul {
    margin: .85rem 0 0;
    padding-left: 1.2rem;
    display: grid;
    gap: .6rem;
  }

  .step-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .step-card span {
    display: inline-block;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: .5rem;
  }

  .step-card p {
    color: var(--dark);
    font-weight: 600;
  }

  .eb-note {
    padding: 1rem 1.1rem;
    border-radius: .9rem;
    background: var(--light-soft);
    border: 1px solid var(--border);
  }

  .eb-note strong {
    color: var(--dark);
  }

  .eb-note li {
    color: var(--secondary-dark);
    line-height: 1.6;
  }

  .eb-process {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 960px) {
    .eb-hero-grid,
    .eb-custom,
    .eb-cta {
      grid-template-columns: 1fr;
    }

    .plan-grid,
    .step-row {
      grid-template-columns: 1fr;
    }
  }
</style>
